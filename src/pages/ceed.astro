---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Lightbox from '../components/Lightbox.astro';

// CEED（マルチクリエイティブサークル・愛知工業大学）。大崎＝副部長。
// 事実の出典はVol.1のceed.astro（一次資料で担当確認済み）。数字・実績の捏造は禁止。
// 運動会・ハロウィン等は別サークルの企画＝CEEDに混ぜない（Vol.1の方針を踏襲）。
const socials = [
  { label: 'Instagram', url: 'https://www.instagram.com/ceed.create' },
  { label: 'YouTube', url: 'https://youtube.com/@ceed_ait' },
  { label: 'X', url: 'https://x.com/ceed_create' },
];

// 私が作った発表（スライドは実物・実在ファイルのみ）
const decks = [
  {
    title: 'ワークショップ「Amazon Prime CM分析」',
    role: '企画・登壇・資料制作',
    date: '2024.12.23',
    note: '61ページ、ぜんぶ自作！',
    lead: '感覚じゃなくて“ロジック”でCMを読む90分のチーム戦。企画から司会台本・61ページのスライドまで、一人で作り込みました。',
    article: [
      'Amazon Prime のCMを4本分解して、プロの思考ツール「3段ロジック（インサイト→ベネフィット→根拠）」と「必然性の設計」を体得。',
      'メインワークは“ヒントだけでCMの全構成を当てる”推理戦。「なぜゴミ箱が映る？」「なぜHipHop？」を論理で導く。',
      '締めは「テスト期間の限界大学生を救う15秒CM」をチームで制作・発表。優勝チームには Amazon ギフト券！',
    ],
    slides: [1, 2, 3, 4, 5].map((n) => `/assets/slides/slide-ws-${n}.jpg`),
  },
  {
    title: '新入生向けプレゼン（サークル説明会）',
    role: '制作・登壇',
    date: '2025.4',
    note: '新入生の入口をつくる！',
    lead: '「映像制作を学び、つくり、社会につなげる」CEEDの魅力が伝わるように、構成・配色・図解まで設計して登壇しました。',
    article: [
      '活動（火＝講座／木＝制作）、企業コラボ、習得ソフト（Illustrator / Photoshop / Premiere / After Effects / Maya）、年間スケジュールをひとつの物語に。',
      '初心者から経験者まで“置いてけぼりにしない”入口づくりを意識しました。',
    ],
    slides: [1, 2, 3, 4].map((n) => `/assets/slides/slide-ceed-${n}.jpg`),
  },
];

const webPhotos = [
  { src: '/assets/ceed/web-figma.jpg', cap: 'Figmaでの設計' },
  { src: '/assets/ceed/web-team.jpg', cap: 'WEB班の制作風景' },
  { src: '/assets/ceed/filming.jpg', cap: '撮影・ドローンでの制作' },
];
const builds = [
  {
    role: 'Figma設計・撮影ディレクション・コピー執筆',
    title: '中央製作所 採用サイト（WEB班）',
    desc: '若手求職者のエントリー率を上げる企業の採用サイトを、チームでリデザイン中。技術・営業・品質保証ページのFigmaワイヤーフレーム、撮影イメージの設計、技術紹介ページの文章を担当して、チームの技術面の責任も担っています。',
    link: '/works#cat-web',
    linkLabel: 'Web制作の実績を見る',
  },
  {
    role: '実装・運用設計（1人＋AI）',
    title: 'CEED 公式サイト',
    desc: 'サークル公式サイトを構築中。実装（コード）を一人＋AIで担って、他のメンバーがFigma・文章・写真・告知で関われる運用体制まで設計しました。',
    status: '公開予定',
  },
];

const bbqPhotos = [
  { src: '/assets/ceed/bbq-group.jpg', cap: '新歓BBQ — 約60名の集合写真' },
  { src: '/assets/ceed/bbq-grill.jpg', cap: '炭火を囲んで' },
  { src: '/assets/ceed/bbq-bingo.jpg', cap: 'ビンゴ大会の景品' },
  { src: '/assets/ceed/bbq-seats.jpg', cap: 'テラスでの交流' },
  { src: '/assets/ceed/bbq-pose.jpg', cap: '焼き場で盛り上がる' },
];
const lecturePhotos = [
  { src: '/assets/ceed/lecture.jpg', cap: '満員の701教室（カメラ講座）' },
  { src: '/assets/ceed/camera-lecture.jpg', cap: 'カメラ講座の様子' },
];
const aiPhotos = [
  { src: '/assets/ceed/ai-1.jpg', cap: '「AIが全部作る」は幻想 ― 本当のクリエイティブを学ぶ' },
  { src: '/assets/ceed/ai-2.jpg', cap: '現役デザイナーが語る、AI活用と働き方のリアル' },
  { src: '/assets/ceed/ai-3.jpg', cap: '講座に集まったメンバー' },
  { src: '/assets/ceed/ai-4.jpg', cap: 'AI活用の講習を行う講師' },
];

// CEEDの対外活動（チーム制作＝サークルの実績として）
const team = [
  { t: '14号館 紹介動画', meta: '学内サイネージ展示', d: '学内14号館の紹介動画をチームで制作・撮影して、入口スクリーンで展示。' },
  { t: '東京ゲームショウ 2025 出展動画', meta: '幕張メッセ', d: 'TGS出展チームの紹介動画をチームで制作。' },
  { t: 'NagoyaHack 広告動画＋チラシ', meta: '成果はSNS掲載', d: '広告動画とチラシをチームで制作。' },
  { t: '映像コンテスト出品（TYO ほか）', meta: '各AWARD・映画祭', d: '映像コンテスト・映画祭への出品作品をチームで制作。' },
];

const principles = [
  { ic: '🤝', t: '誰も置いてけぼりにしない', d: '新入生の視点でヒアリングを徹底して、部長と意見をすり合わせて運営に反映。' },
  { ic: '🌱', t: '初心者を孤立させない', d: '技術レベルの差で取り残されないように、段階的な講座やフォローで橋渡し。' },
  { ic: '🎉', t: '交流で距離を縮める', d: 'ワークショップ・BBQなど、学年や技術の壁を越えて話せる場をつくる。' },
];

const lb = (arr: { src: string }[]) => JSON.stringify(arr.map((x) => x.src));
---
<Base
  title="CEED ― 稜馬のアトリエ"
  description="愛知工業大学のマルチクリエイティブサークル CEED（シード）副部長としての活動。発表・スライド制作、Web制作、イベント企画・運営の記録。"
>
  <Nav />
  <main id="main">
    <!-- ===== ヒーロー ===== -->
    <header class="chero">
      <div class="wrap chero-grid">
        <div class="chero-copy">
          <p class="eyebrow"><span class="dot"></span>CLUB · 学生団体 CEED</p>
          <h1 class="ctitle">CEEDで、<br /><span class="am">つくって届ける。
            <svg class="draw-line under" viewBox="0 0 340 18" preserveAspectRatio="none" aria-hidden="true" style="--len:360">
              <path d="M6,12 C70,4 130,16 190,9 C240,3 300,14 334,7" />
            </svg>
          </span></h1>
          <p class="clead">
            愛知工業大学のマルチクリエイティブサークル <b>CEED（シード）</b>で<b>副部長</b>をしています。
            発表・スライド制作、Web制作、イベント企画・運営 ―― 「つくって人に届ける」を横断して、
            <b>60名規模</b>のコミュニティへ育つ過程に関わってきました。
          </p>
          <ul class="chips" aria-label="CEEDの基本情報">
            <li><b>活動</b>火（講座）・木（制作）16:30〜</li>
            <li><b>場所</b>1号館 701教室</li>
            <li><b>領域</b>映像・CG・デザイン</li>
            <li><b>歓迎</b>見学・講座参加もOK</li>
          </ul>
          <div class="slinks">
            {socials.map((s) => (
              <a class="slink" href={s.url} target="_blank" rel="noopener">{s.label}<span aria-hidden="true">↗</span></a>
            ))}
            <span class="slink is-soon">公式サイト（公開予定）</span>
          </div>
        </div>

        <!-- 右：現場写真＝テープ留めの一枚 -->
        <figure class="chero-photo reveal d1">
          <span class="tape t1" aria-hidden="true"></span>
          <span class="tape t2" aria-hidden="true"></span>
          <img src="/assets/ceed/filming2.jpg" alt="CEEDの制作風景 — 撮影に集中するメンバー" loading="eager" />
          <figcaption class="hand">つくる現場！
            <svg class="cap-arrow" viewBox="0 0 46 30" aria-hidden="true"><path d="M40,26 C30,12 20,6 6,4 M6,4 l9,3 M6,4 l1,9" /></svg>
          </figcaption>
          <span class="clogo"><img src="/assets/ceed-logo.png" alt="CEEDのロゴ" loading="eager" /></span>
          <span class="hanko-mini" aria-hidden="true">馬</span>
        </figure>
      </div>
    </header>

    <!-- ===== 01 WEB班 ===== -->
    <section class="section web-sec">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>01 — WEB班</p>
        <h2 class="big reveal d1">つくり、任され、<span class="am2">まとめる。</span></h2>

        <div class="pgrid reveal d2">
          {webPhotos.map((p, i) => (
            <button class={`pcard r${i % 3}`} data-gallery={lb(webPhotos)} data-index={i} data-caption={p.cap} aria-label={`${p.cap} を拡大`}>
              <span class="tape" aria-hidden="true"></span>
              <img src={p.src} alt={p.cap} loading="lazy" />
              <span class="pcap hand">{p.cap}</span>
            </button>
          ))}
        </div>

        <div class="build-grid">
          {builds.map((b, i) => (
            <article class={`bcard reveal d${i + 1}`}>
              <span class="role-tag">{b.role}</span>
              <h3>{b.title}</h3>
              <p>{b.desc}</p>
              {b.link && <a class="btn ghost" href={b.link}>{b.linkLabel} →</a>}
              {b.status && <span class="stamp-soon">{b.status}</span>}
            </article>
          ))}
          <img class="uma-handoff" src="/assets/mascot/handoff.png" alt="" aria-hidden="true" />
        </div>
      </div>
    </section>

    <!-- ===== 02 イベント企画 ===== -->
    <section class="section event-sec">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>02 — イベント企画・運営</p>
        <h2 class="big reveal d1">人が集まる場を、<span class="am2">つくる。</span></h2>
        <p class="sec-lead reveal d2">副部長として、部員が楽しめて交流が生まれる場を、企画から当日の進行まで担当しました。</p>

        <div class="feat">
          <button class="pcard pcard-lg reveal d1" data-gallery={lb(bbqPhotos)} data-index={0} data-caption={bbqPhotos[0].cap} aria-label={`${bbqPhotos[0].cap} を拡大`}>
            <span class="tape amber" aria-hidden="true"></span>
            <img src={bbqPhotos[0].src} alt={bbqPhotos[0].cap} loading="lazy" />
            <span class="pcap hand">{bbqPhotos[0].cap}</span>
          </button>
          <div class="feat-side">
            <div class="feat-text reveal d2">
              <span class="role-tag">企画・運営</span>
              <h3>新歓バーベキュー ＆ ビンゴ大会</h3>
              <p>約60名規模の新歓を企画・運営！買い出し・会場図・名札・当日の役割分担まで設計して、現場の進行も担当しました。</p>
              <img class="uma-cheers" src="/assets/mascot/wave.png" alt="" aria-hidden="true" />
            </div>
            {bbqPhotos.slice(1).map((p, i) => (
              <button class={`pcard pcard-sm reveal d${(i % 2) + 2}`} data-gallery={lb(bbqPhotos)} data-index={i + 1} data-caption={p.cap} aria-label={`${p.cap} を拡大`}>
                <img src={p.src} alt={p.cap} loading="lazy" />
                <span class="pcap hand">{p.cap}</span>
              </button>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ===== 03 CEEDのみんなと ===== -->
    <section class="section circle-sec">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>03 — CEEDのみんなと</p>
        <h2 class="big reveal d1">サークルとして、<span class="am2">社会につなげる。</span></h2>
        <p class="sec-lead reveal d2">ここからはチームでの取り組み（個人の成果じゃなくて、サークルの実績として）。副部長として運営に関わっています。</p>

        <!-- 技術講座 -->
        <div class="block reveal">
          <div class="block-text">
            <span class="role-tag">運営担当</span>
            <h3>クリエイティブ技術講座</h3>
            <p class="block-meta">Illustrator / Photoshop / カメラ ・ 隔月</p>
            <p>部員のスキルアップのための講座を隔月で開催。<b>副部長として運営</b>を担当しています（登壇・資料制作は各担当者）。振り返りアンケートでは「ばっちり理解できた」の声が多数で、「次はポスターやロゴを作りたい」と創作意欲につながっています。</p>
          </div>
          <div class="pgrid pgrid-2">
            {lecturePhotos.map((p, i) => (
              <button class={`pcard r${i % 2}`} data-gallery={lb(lecturePhotos)} data-index={i} data-caption={p.cap} aria-label={`${p.cap} を拡大`}>
                <span class="tape" aria-hidden="true"></span>
                <img src={p.src} alt={p.cap} loading="lazy" />
                <span class="pcap hand">{p.cap}</span>
              </button>
            ))}
          </div>
        </div>

        <!-- AI講座 -->
        <div class="block block-rev reveal">
          <div class="block-text">
            <span class="role-tag">運営・まとめ担当</span>
            <h3>AI講座 ― AI時代のデザインの仕事</h3>
            <p class="block-meta">外部デザイナー登壇</p>
            <p>現役デザイナーを招いて「AIをどう使って、どう価値を出すか」を学ぶ講座を開催。要点を記事にまとめました：</p>
            <ul class="deck-list">
              <li>デザインとは“対話で課題を解決”すること。提案は必ず複数案を持っていく。</li>
              <li>言葉の<b>裏にある意図</b>を読む。リクエストの真の目的を掴む。</li>
              <li>AIは情報整理・調査・批評の相棒。<b>最終判断は人間</b>が握る。</li>
            </ul>
          </div>
          <div class="pgrid pgrid-2">
            {aiPhotos.map((p, i) => (
              <button class={`pcard r${i % 2}`} data-gallery={lb(aiPhotos)} data-index={i} data-caption={p.cap} aria-label={`${p.cap} を拡大`}>
                <span class="tape" aria-hidden="true"></span>
                <img src={p.src} alt={p.cap} loading="lazy" />
                <span class="pcap hand">{p.cap}</span>
              </button>
            ))}
          </div>
        </div>

        <!-- 対外活動 -->
        <ul class="team">
          {team.map((t) => (
            <li class="titem reveal">
              <div class="titem-h"><h3>{t.t}</h3><span class="titem-meta">{t.meta}</span></div>
              <p>{t.d}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ===== 04 大切にしていること ===== -->
    <section class="section phil-sec">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>04 — 企画で大切にしていること</p>
        <h2 class="big reveal d1">イベントは、人が定着するための<span class="am2">手段。</span></h2>
        <p class="sec-lead reveal d2">「楽しい」だけじゃなくて、交流を深めて、組織に人が定着するための手段だと考えています。</p>

        <div class="memos">
          {principles.map((p, i) => (
            <article class={`memo reveal d${i + 1}`}>
              <span class="pin" aria-hidden="true"></span>
              <span class="m-ic" aria-hidden="true">{p.ic}</span>
              <h3 class="m-t">{p.t}</h3>
              <p class="m-d">{p.d}</p>
            </article>
          ))}
        </div>

        <p class="result reveal">✎ 心理的安全性の高いコミュニティづくりに貢献して、サークルは<span class="am-mark">60名規模
          <svg class="draw-line r-under" viewBox="0 0 200 14" preserveAspectRatio="none" aria-hidden="true" style="--len:220">
            <path d="M5,9 C50,3 100,12 150,7 C175,4 190,9 195,7" />
          </svg></span>へ成長しました。
        </p>
      </div>
    </section>

    <!-- ===== 05 発表・スライド（アーカイブ的に最後へ） ===== -->
    <section class="section decks-sec">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>05 — 発表・スライド制作</p>
        <h2 class="big reveal d1">「何を・どの順で・どう見せるか」を<span class="am2">設計する。</span></h2>
        <p class="sec-lead reveal d2">登壇の機会が多くて、企画・台本・スライドまで一貫して作るのが得意です。実物を抜粋で載せます！</p>

        {decks.map((d, di) => (
          <article class={`deck reveal d${di + 1}`}>
            <span class={`tape ${di % 2 ? '' : 'amber'}`} aria-hidden="true"></span>
            <div class="deck-head">
              <p class="role-row">
                <span class="role-tag">{d.role}</span>
                <span class="role-date">{d.date}</span>
                <span class="deck-note hand">{d.note}</span>
              </p>
              <h3 class="deck-title">{d.title}</h3>
              <p class="deck-lead">{d.lead}</p>
              <ul class="deck-list">{d.article.map((a) => <li>{a}</li>)}</ul>
            </div>
            <p class="strip-hint hand" aria-hidden="true">→ 横にスクロール・クリックで拡大！</p>
            <div class="filmstrip" role="list" aria-label={`${d.title} のスライド`}>
              {d.slides.map((s, j) => (
                <button class="slide" role="listitem" data-gallery={JSON.stringify(d.slides)} data-index={j} data-caption={d.title} aria-label={`スライド ${j + 1} を拡大`}>
                  <img src={s} alt={`${d.title} スライド ${j + 1}`} loading="lazy" />
                  <span class="slide-no" aria-hidden="true">{j + 1}</span>
                </button>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ===== つぎへ ===== -->
    <div class="wrap outro reveal">
      <img class="omu" src="/assets/mascot/run2.png" alt="" aria-hidden="true" />
      <div>
        <p class="o-note hand">サークルの外でも、いっぱい作ってます！</p>
        <div class="cta-row">
          <a class="btn" href="/works">作品を見る<span class="ar">→</span></a>
          <a class="btn ghost" href="/about">ぼくのこと →</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
  <Lightbox />
</Base>

<style>
  /* ===== ヒーロー ===== */
  .chero { padding-top: clamp(2rem, 6vw, 4rem); }
  .chero-grid { display: grid; grid-template-columns: 1.1fr .9fr; gap: clamp(1.6rem, 4.5vw, 3.4rem); align-items: center; }
  .ctitle { font-size: clamp(2.5rem, 7vw, 4.6rem); line-height: 1.12; }
  .ctitle .am { position: relative; display: inline-block; color: var(--scarlet-d); }
  .draw-line.under { position: absolute; left: -1%; bottom: -.1em; width: 102%; height: .2em; overflow: visible; }
  .draw-line.under path { fill: none; stroke: var(--amber); stroke-width: 8; stroke-linecap: round; }
  .clead { margin-top: 1.3rem; font-weight: 600; font-size: clamp(.96rem, 1.9vw, 1.12rem); line-height: 2; max-width: 46ch; }
  .clead b { border-bottom: 3px solid var(--amber); font-weight: 800; }

  .chips { list-style: none; margin: 1.5rem 0 0; padding: 0; display: flex; flex-wrap: wrap; gap: .5rem .6rem; }
  .chips li {
    font-family: var(--f-round); font-weight: 700; font-size: .82rem; color: var(--ink);
    background: var(--card); border: 1.5px solid color-mix(in oklab, var(--ink) 22%, transparent);
    padding: .34rem .8rem; border-radius: var(--r-pill); box-shadow: var(--sh-1);
  }
  .chips li b { font-family: var(--f-mono); font-size: .66rem; color: var(--scarlet-d); margin-right: .5em; letter-spacing: .08em; }

  .slinks { display: flex; flex-wrap: wrap; gap: .6rem; margin-top: 1.4rem; }
  .slink {
    display: inline-flex; align-items: center; gap: .35rem;
    font-family: var(--f-mono); font-weight: 700; font-size: .78rem; color: var(--ink);
    border: 2px solid var(--ink); border-radius: var(--r-pill); padding: .42rem 1rem;
    background: var(--card); text-decoration: none;
    transition: translate .2s var(--spring), box-shadow .2s ease, color .2s ease, border-color .2s ease;
  }
  .slink:hover { translate: 0 -3px; box-shadow: var(--sh-2); color: var(--scarlet-d); border-color: var(--scarlet-d); }
  .slink.is-soon { opacity: .55; border-style: dashed; pointer-events: none; }

  /* 右：テープ留め写真 */
