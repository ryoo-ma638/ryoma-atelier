---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Lightbox from '../../components/Lightbox.astro';
import { works, categoryLabels, type Category } from '../../data/works.ts';

export function getStaticPaths() {
  return works.map((w) => ({ params: { slug: w.slug } }));
}

const { slug } = Astro.params;
const work = works.find((w) => w.slug === slug)!;
const cat = categoryLabels[work.category];

// 作品ページと同じ並びで前後の作品を決める
const order: Category[] = ['web', 'imaging', 'cg', 'video', 'planning', 'graphic', 'sound'];
const flat = order.flatMap((c) => works.filter((w) => w.category === c));
const idx = flat.findIndex((w) => w.slug === slug);
const prev = flat[(idx - 1 + flat.length) % flat.length];
const next = flat[(idx + 1) % flat.length];

const externalLink = work.link?.startsWith('http');
const galleryJson = work.gallery ? JSON.stringify(work.gallery) : null;
---
<Base title={`${work.title} ― 稜馬のアトリエ`} description={work.summary}>
  <Nav />
  <main id="main">
    <article class="wd wrap">
      <!-- ===== パンくず ===== -->
      <p class="crumb reveal">
        <a href={`/works#cat-${work.category}`}>← 作品いちらん</a>
        <span class="tag" style={`--tag:${cat.color}`}>{cat.ja}</span>
        {work.status && <span class="status">{work.status}</span>}
      </p>

      <!-- ===== ヒーロー（メディア＋情報） ===== -->
      <div class="head">
        <div class="media" transition:name={`w-${work.slug}`} style={`--tag:${cat.color}`}>
          {work.video
            ? <video data-autoplay src={work.video} poster={work.thumb} muted loop playsinline preload="none"></video>
            : work.thumb
              ? <img src={work.thumb} alt={work.title} data-gallery={galleryJson ?? JSON.stringify([work.thumb])} data-caption={work.title} />
              : <span class="noimg"><img src="/assets/mascot/logo3d.png" alt="" /><span class="hand">いま準備中！</span></span>}
          <span class="tape" aria-hidden="true"></span>
        </div>

        <div class="info">
          <h1 class="title">{work.title}</h1>
          <p class="sum">{work.summary}</p>

          <dl class="meta">
            {work.tools && (
              <div class="row"><dt>つかったもの</dt><dd class="chips">{work.tools.map((t) => <span class="chip">{t}</span>)}</dd></div>
            )}
            {work.duration && (
              <div class="row"><dt>制作時間</dt><dd>{work.duration}</dd></div>
            )}
          </dl>

          <div class="acts">
            {work.link && (
              externalLink
                ? <a class="btn" href={work.link} target="_blank" rel="noopener">サイトを見る<span class="ar">↗</span></a>
                : <a class="btn" href={work.link}>サイトへ行く<span class="ar">→</span></a>
            )}
            {work.links?.map((l) => (
              <a class="btn ghost" href={l.href} target="_blank" rel="noopener">{l.label} ↗</a>
            ))}
          </div>
        </div>
      </div>

      <!-- ===== ねらい / 工夫 ===== -->
      {(work.goal || work.approach) && (
        <div class="ga">
          {work.goal && (
            <section class="ga-card reveal d1">
              <span class="tape" aria-hidden="true"></span>
              <h2 class="hand">✎ ねらい</h2>
              <p>{work.goal}</p>
            </section>
          )}
          {work.approach && (
            <section class="ga-card reveal d2">
              <span class="tape t2" aria-hidden="true"></span>
              <h2 class="hand">✎ 工夫したこと</h2>
              <p>{work.approach}</p>
            </section>
          )}
        </div>
      )}

      <!-- ===== ギャラリー ===== -->
      {work.gallery && work.gallery.length > 0 && (
        <section class="sec reveal">
          <p class="eyebrow"><span class="dot"></span>ギャラリー <span class="mut">（クリックで拡大）</span></p>
          <div class="gal">
            {work.gallery.map((g, gi) => (
              <button class="shot" type="button" data-gallery={JSON.stringify(work.gallery)} data-index={gi} data-caption={work.title}>
                <img src={g} alt={`${work.title} スクリーンショット ${gi + 1}`} loading="lazy" />
              </button>
            ))}
          </div>
        </section>
      )}

      <!-- ===== スライド（ページ別・横スクロール） ===== -->
      {work.slideGroups?.map((sg) => (
        <section class="sec reveal">
          <p class="eyebrow"><span class="dot"></span>{sg.title}</p>
          <div class="slides">
            {sg.images.map((s, si) => (
              <button class="slide" type="button" data-gallery={JSON.stringify(sg.images)} data-index={si} data-caption={sg.title}>
                <img src={s} alt={`${sg.title} ${si + 1}`} loading="lazy" />
              </button>
            ))}
          </div>
        </section>
      ))}

      <!-- ===== 音源 ===== -->
      {work.audio && work.audio.length > 0 && (
        <section class="sec reveal">
          <p class="eyebrow"><span class="dot"></span>きいてみる</p>
          <div class="tracks">
            {work.audio.map((a) => (
              <div class="track">
                <p class="t-name">🎧 {a.title}</p>
                {a.note && <p class="t-note">{a.note}</p>}
                <audio controls preload="none" src={a.src}></audio>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- ===== 前後の作品 ===== -->
      <nav class="pn reveal" aria-label="前後の作品">
        <a class="pn-card" href={`/works/${prev.slug}`}>
          <span class="pn-dir">← まえ</span>
          {prev.thumb && <img src={prev.thumb} alt="" loading="lazy" />}
          <span class="pn-title">{prev.title}</span>
        </a>
        <a class="pn-all" href="/works">ぜんぶ<br />見る</a>
        <a class="pn-card next" href={`/works/${next.slug}`}>
          <span class="pn-dir">つぎ →</span>
          {next.thumb && <img src={next.thumb} alt="" loading="lazy" />}
          <span class="pn-title">{next.title}</span>
        </a>
      </nav>

      <!-- ===== CTA ===== -->
      <div class="cta reveal">
        <img class="uma" src="/assets/mascot/handoff2.png" alt="" loading="lazy" />
        <p class="hand">気に入ってくれたら、うれしいです！</p>
        <a class="btn" href="#contact">声、かけてください →</a>
      </div>
    </article>
  </main>
  <Lightbox />
  <Footer />
</Base>

<style>
  .wd { padding-top: clamp(1.5rem, 4vw, 3rem); }

  .crumb { display: flex; align-items: center; gap: .8rem; flex-wrap: wrap; }
  .crumb a { font-weight: 700; border-bottom: 2px solid var(--ink); padding-bottom: 1px; }
  .crumb a:hover { color: var(--scarlet); border-color: var(--scarlet); }
  .status { font-family: var(--f-mono); font-size: .62rem; font-weight: 700; background: var(--ink); color: var(--paper); padding: .28rem .6rem; border-radius: var(--r-sm); }

  /* ---- ヒーロー ---- */
  .head { display: grid; grid-template-columns: 1.15fr .85fr; gap: clamp(1.2rem, 3.5vw, 2.6rem); align-items: start; margin-top: 1.2rem; }
  .media { position: relative; border-radius: var(--r-lg); overflow: hidden; background: var(--paper-3); border: 2px solid var(--ink); box-shadow: var(--sh-3); }
  .media::before { content: ''; position: absolute; left: 0; right: 0; top: 0; height: 5px; background: var(--tag); z-index: 2; }
  .media video, .media img { width: 100%; aspect-ratio: 16 / 10; object-fit: cover; display: block; }
  .media .noimg { aspect-ratio: 16/10; display: grid; place-items: center; gap: .4rem; padding: 2rem;
    background: repeating-linear-gradient(45deg, var(--paper-3), var(--paper-3) 14px, var(--paper-2) 14px, var(--paper-2) 28px); }
  .media .noimg img { width: 90px; aspect-ratio: auto; }
  .media .tape { top: -10px; left: 14%; transform: rotate(-6deg); }

  .title { font-size: clamp(1.7rem, 4.2vw, 2.9rem); line-height: 1.25; }
  .sum { margin-top: .9rem; font-weight: 700; line-height: 2; }

  .meta { margin-top: 1.2rem; display: grid; gap: .6rem; }
  .meta .row { display: grid; grid-template-columns: 108px 1fr; gap: .6rem; align-items: baseline; }
  .meta dt { font-family: var(--f-mono); font-size: .66rem; font-weight: 700; color: var(--amber-d); letter-spacing: .08em; }
  .meta dd { font-weight: 700; font-size: .92rem; }
  .chips { display: flex; flex-wrap: wrap; gap: .35rem; }
  .chip { font-family: var(--f-mono); font-size: .66rem; padding: .22rem .55rem; border-radius: var(--r-sm); background: var(--paper-3); }

  .acts { display: flex; gap: .8rem; flex-wrap: wrap; margin-top: 1.4rem; }
  .acts .ar { margin-left: .2rem; }

  /* ---- ねらい/工夫 ---- */
  .ga { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1rem, 2.5vw, 1.6rem); margin-top: clamp(1.8rem, 4vw, 2.8rem); align-items: start; }
  .ga-card { position: relative; background: var(--card); border: 2px solid var(--ink); border-radius: var(--r-lg); padding: 1.5rem 1.5rem 1.3rem; box-shadow: var(--sh-2); }
  .ga-card h2 { font-size: 1.15rem; color: var(--scarlet-d); margin-bottom: .6rem; transform: rotate(-1deg); width: fit-content; }
  .ga-card p { color: var(--ink-2); font-weight: 500; line-height: 1.95; }
  .ga-card .tape.t2 { background: color-mix(in oklab, var(--scarlet) 30%, #fff 36%); transform: translateX(-50%) rotate(4deg); }

  /* ---- ギャラリー/スライド ---- */
  .sec { margin-top: clamp(2rem, 4.5vw, 3rem); }
  .sec .mut { color: var(--mut); font-size: .8em; }
  .gal { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: .9rem; margin-top: 1rem; }
  .shot, .slide { padding: 0; border: 2px solid var(--ink); border-radius: var(--r-md); overflow: hidden; background: var(--card); box-shadow: var(--sh-1); cursor: zoom-in; transition: transform .2s var(--spring), box-shadow .2s ease; }
  .shot:hover, .slide:hover { transform: translateY(-5px) rotate(-.6deg); box-shadow: var(--sh-2); }
  .shot img { width: 100%; aspect-ratio: 16/10; object-fit: cover; display: block; }

  .slides { display: flex; gap: .9rem; overflow-x: auto; padding: 1rem .2rem .6rem; scrollbar-width: thin; }
  .slide { flex: 0 0 auto; width: min(420px, 74vw); }
  .slide img { width: 100%; aspect-ratio: 16/10; object-fit: contain; background: #fff; display: block; }

  /* ---- 音源 ---- */
  .tracks { display: grid; gap: .9rem; margin-top: 1rem; }
  .track { background: var(--card); border: 2px solid var(--ink); border-radius: var(--r-md); padding: 1rem 1.2rem; box-shadow: var(--sh-1); }
  .t-name { font-weight: 700; }
  .t-note { color: var(--mut); font-size: .85rem; margin: .2rem 0 .5rem; }
  .track audio { width: 100%; }

  /* ---- 前後ナビ ---- */
  .pn { display: grid; grid-template-columns: 1fr auto 1fr; gap: 1rem; margin-top: clamp(2.4rem, 5vw, 3.6rem); align-items: stretch; }
  .pn-card { display: grid; grid-template-columns: 84px 1fr; grid-template-rows: auto auto; gap: .15rem .8rem; align-items: center;
    background: var(--card); border: 2px solid var(--ink); border-radius: var(--r-md); padding: .7rem .9rem; box-shadow: var(--sh-1);
    transition: transform .2s var(--spring), box-shadow .2s ease; }
  .pn-card:hover { transform: translateY(-4px); box-shadow: var(--sh-2); }
  .pn-card img { grid-row: 1 / span 2; width: 84px; aspect-ratio: 16/10; object-fit: cover; border-radius: 8px; }
  .pn-dir { font-family: var(--f-mono); font-size: .62rem; font-weight: 700; color: var(--amber-d); }
  .pn-title { font-weight: 700; font-size: .84rem; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .pn-card.next { text-align: right; grid-template-columns: 1fr 84px; }
  .pn-card.next img { grid-column: 2; }
  .pn-card.next .pn-dir, .pn-card.next .pn-title { grid-column: 1; }
  .pn-all { align-self: center; font-family: var(--f-round); font-weight: 700; font-size: .8rem; text-align: center; line-height: 1.3;
    background: var(--amber); color: #3a2606; border-radius: 50%; width: 74px; height: 74px; display: grid; place-items: center;
    box-shadow: 0 4px 0 var(--amber-d); transition: transform .15s var(--spring); }
  .pn-all:hover { transform: translateY(-3px) rotate(-4deg); }

  /* ---- CTA ---- */
  .cta { display: flex; align-items: center; gap: 1.2rem; flex-wrap: wrap; justify-content: center; margin-top: clamp(2.4rem, 5vw, 3.4rem); text-align: center; }
  .cta .uma { width: 110px; filter: drop-shadow(3px 5px 5px rgba(27,42,74,.2)); }
  .cta .hand { font-size: 1.15rem; color: var(--scarlet-d); transform: rotate(-1.5deg); }

  @media (max-width: 860px) {
    .head { grid-template-columns: 1fr; }
    .ga { grid-template-columns: 1fr; }
    .pn { grid-template-columns: 1fr; }
    .pn-all { justify-self: center; }
    .pn-card.next { text-align: left; grid-template-columns: 84px 1fr; }
    .pn-card.next img { grid-column: 1; grid-row: 1 / span 2; }
    .pn-card.next .pn-dir, .pn-card.next .pn-title { grid-column: 2; }
  }
</style>
