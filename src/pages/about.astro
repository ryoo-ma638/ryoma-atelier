---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { works } from '../data/works.ts';
import Calendar from '../components/Calendar.astro';

const kama = works.find((w) => w.slug === 'death-comer');

const facts = [
  { k: '名前', v: '大崎稜馬（おおさき りょうま）' },
  { k: '学び', v: '愛知工業大学 情報科学部 メディア情報専攻・3年' },
  { k: '研究室', v: '水野慎士研究室（CG・画像処理・インタラクション）' },
  { k: 'サークル', v: 'CEED（シード）副部長' },
  { k: 'もう一つの顔', v: 'バンテリンドームのビール売り子（自己プロデュース）' },
  { k: '性格', v: '愛嬌がある・元気・まっすぐ・諦めない' },
];
const skills = [
  { g: 'つくる（CG・画像処理）', icon: '🖥️', color: 'var(--c-violet)', items: ['C++ / OpenGL', 'OpenCV', 'Maya', 'LiDAR / センサー'] },
  { g: 'つくる（Web・アプリ）', icon: '📱', color: 'var(--c-blue)', items: ['Astro / TypeScript', 'HTML / CSS / JS', 'Firebase', 'Vercel'] },
  { g: 'つたえる（企画・発表）', icon: '📣', color: 'var(--c-green)', items: ['スライド制作', 'イベント企画', 'グラフィック / ロゴ'] },
];
---
<Base title="ぼく ― 稜馬のアトリエ" description="大崎稜馬について。つくる人で、バンテリンドームのビール売り子。諦めずに、あたたかい作品をつくります。">
  <Nav />
  <main id="main">
    <!-- ===== イントロ ===== -->
    <header class="ahero">
      <div class="wrap intro-grid">
        <div class="intro-copy">
          <p class="eyebrow"><span class="dot"></span>ABOUT · ぼくのこと</p>
          <h1 class="atitle">つくる人で、<br /><span class="am">ビール売り子。
            <svg class="draw-line under" viewBox="0 0 340 18" preserveAspectRatio="none" aria-hidden="true" style="--len:360">
              <path d="M6,12 C70,4 130,16 190,9 C240,3 300,14 334,7" />
            </svg>
          </span></h1>
          <p class="alead">
            大崎稜馬です。愛知工業大学でCGと画像処理をつくってる3年生。<br />
            「これだ」と思ったら、動くまで諦めません。<br />
            <b>作品も、ビールも、自分の手で人に手渡す</b>のが好きです。
          </p>
        </div>

        <!-- 案内役うまくん（琥珀スプラッシュ＋紙吹雪） -->
        <div class="portrait" aria-hidden="false">
          <svg class="p-splash" viewBox="0 0 640 560" preserveAspectRatio="none" aria-hidden="true">
            <path d="M120,540 C40,470 60,380 140,330 C90,260 130,160 230,130 C250,60 350,20 440,50 C520,10 610,60 620,150 C660,240 600,330 520,360 C520,440 440,510 340,500 C270,560 170,580 120,540 Z" />
          </svg>
          <svg class="p-swoosh" viewBox="0 0 600 500" preserveAspectRatio="none" aria-hidden="true">
            <path d="M30,470 L200,300 C280,215 380,120 470,60 L575,8 C592,0 604,16 592,30 L470,170 C380,270 260,380 140,465 L55,498 C36,506 16,486 30,470 Z" />
          </svg>
          <span class="cf c1" aria-hidden="true"></span><span class="cf c2" aria-hidden="true"></span>
          <span class="cf c3" aria-hidden="true"></span><span class="cf c4" aria-hidden="true"></span>
          <span class="cf c5" aria-hidden="true"></span>
          <img class="avatar" src="/assets/mascot/wave.png" alt="手を振る案内役のうまくん" />
          <span class="p-hello hand">ようこそ！</span>
          <span class="hanko-mini" aria-hidden="true">馬</span>
        </div>
      </div>

      <div class="wrap facts-block">
        <p class="facts-label hand">ぼくの基本情報
          <svg class="f-arrow" viewBox="0 0 46 30" aria-hidden="true"><path d="M6,4 C16,18 26,24 40,26 M40,26 l-9,-3 M40,26 l-1,-9" /></svg>
        </p>
        <div class="facts">
          {facts.map((f, i) => (
            <div class={`fact reveal d${(i % 3) + 1}`}>
              <span class="pin" aria-hidden="true"></span>
              <span class="fk">{f.k}</span>
              <span class="fv">{f.v}</span>
            </div>
          ))}
        </div>
      </div>
    </header>

    <!-- ===== 二面性 ===== -->
    <section class="section duo">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>01 — ふたつの顔</p>
        <div class="duo-grid">
          <article class="panel reveal d1">
            <span class="tape" aria-hidden="true"></span>
            <span class="ic" aria-hidden="true">🛠️</span>
            <h3>つくる人</h3>
            <p>CG・画像処理・Web・ゲーム。水野研究室で、手を動かしてつくる。「動かない」で終わらせず、原因を突き止めて作り直す。</p>
          </article>
          <span class="amp" aria-hidden="true">×</span>
          <article class="panel sell reveal d2">
            <span class="tape red" aria-hidden="true"></span>
            <span class="ic" aria-hidden="true">🍺</span>
            <h3>ビール売り子</h3>
            <p>バンテリンドームで、自分をプロデュースして売る。届け方まで自分ごと。現場の熱と、まっすぐな声かけが武器。</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ===== 諦めなかった一本（鎌ゲーム） ===== -->
    <section class="section story">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>02 — 諦めなかった一本</p>
        <h2 class="big reveal d1">動かなかった。<span class="am">だから、作り直した。
          <svg class="draw-line s-under" viewBox="0 0 340 18" preserveAspectRatio="none" aria-hidden="true" style="--len:360">
            <path d="M6,12 C70,5 130,15 190,8 C240,4 300,13 334,6" />
          </svg>
        </span></h2>
        <p class="lead reveal d2">{kama?.title}</p>

        <div class="ba">
          <article class="ba-card before reveal d1">
            <span class="tape" aria-hidden="true"></span>
            <span class="ba-tag">BEFORE</span>
            <h3>発表で、<span class="circled">動かなかった<svg class="draw-line" viewBox="0 0 200 60" preserveAspectRatio="none" aria-hidden="true" style="--len:580"><path d="M14,30 C22,9 178,5 189,26 C195,47 32,57 15,40 C7,32 12,18 26,13" /></svg></span>。</h3>
            <p>デジコン演習(2025)で発表 ―― LiDARと鎌のセンサーで全身操作する設置型ゲーム。でも本番、思うように動かなかった。<span class="redink">＝ここで諦めない。<svg class="scribble" viewBox="0 0 160 12" preserveAspectRatio="none" aria-hidden="true"><path d="M4,8 C40,3 80,11 156,5" /></svg></span></p>
          </article>

          <span class="arrow reveal d2" aria-hidden="true">
            <svg viewBox="0 0 90 60"><path d="M6,12 C34,8 60,22 78,44 M78,44 l-14,-4 M78,44 l1,-14" /></svg>
            <span class="hand">作りなおす！</span>
          </span>

          <article class="ba-card after reveal d3">
            <span class="tape amber" aria-hidden="true"></span>
            <span class="ba-tag on">AFTER</span>
            <div class="media">
              {kama?.video
                ? <video src={kama.video} muted loop playsinline preload="none" poster={kama.thumb}></video>
                : <img src={kama?.thumb} alt={kama?.title} />}
              <span class="badge">開発中 · 水野研で再設計</span>
            </div>
            <h3>原因は“コードの調整”だった。</h3>
            <p>ハードのせいだと思い込まず、精読で原因を突き止めた。向きの一本化・防御のノイズ対策・デバッグ表示…と直し続け、いまも研究として継続開発中。</p>
          </article>
        </div>

        <p class="redink-note reveal">✎ 「これだ」と思ったものは、動くまでやめない。それがぼくの作り方です。
          <svg class="scribble" viewBox="0 0 300 12" preserveAspectRatio="none" aria-hidden="true"><path d="M4,8 C70,3 150,11 296,5" /></svg>
        </p>
      </div>
    </section>

    <!-- ===== 売り子 ===== -->
    <section class="section uriko">
      <div class="wrap uriko-grid">
        <div class="uriko-photo reveal d1">
          <div class="ph"><img src="/assets/photo/hero.jpg" alt="バンテリンドームのビール売り子（イメージ）" /></div>
          <span class="tape t1" aria-hidden="true"></span>
          <span class="tape t2" aria-hidden="true"></span>
          <span class="u-note hand">現場のぼく！
            <svg class="u-arrow" viewBox="0 0 46 30" aria-hidden="true"><path d="M40,4 C30,18 20,24 6,26 M6,26 l9,-3 M6,26 l1,-9" /></svg>
          </span>
          <img class="cheers" src="/assets/mascot/cheers.png" alt="" aria-hidden="true" />
        </div>
        <div>
          <p class="eyebrow reveal"><span class="dot"></span>03 — もう一つの現場</p>
          <h2 class="big reveal d1">ドームで、<span class="am">まっすぐ売る。</span></h2>
          <p class="lead reveal d2">バンテリンドームのビール売り子。ただ売るんじゃなくて、自分をプロデュースして、笑顔と一緒に手渡す。人に届けることの楽しさは、ものづくりと地続きです。</p>
          <p class="u-chips reveal d3">
            <span>🍺 バンテリンドーム</span>
            <span>😊 自己プロデュース</span>
            <span>🤝 手渡しがすき</span>
          </p>
        </div>
      </div>
    </section>

    <!-- ===== 売り子カレンダー ===== -->
    <Calendar />

    <!-- ===== できること ===== -->
    <section class="section skills">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>04 — できること</p>
        <div class="skill-grid">
          {skills.map((s, i) => (
            <div class={`skill reveal d${i + 1}`} style={`--tag:${s.color}`}>
              <span class="sic" aria-hidden="true">{s.icon}</span>
              <h3>{s.g}</h3>
              <ul>{s.items.map((it) => <li>{it}</li>)}</ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== つぎへ ===== -->
    <div class="wrap outro reveal">
      <img class="omu" src="/assets/mascot/handoff2.png" alt="" aria-hidden="true" />
      <div>
        <p class="o-note hand">つぎは、作品を見てって！</p>
        <div class="cta-row">
          <a class="btn" href="/works">作品を見る<span class="ar">→</span></a>
          <a class="btn ghost" href="mailto:osaki638ryoma@gmail.com">声かけて ✉️</a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .ahero { padding-top: clamp(2rem, 6vw, 4rem); }
  .intro-grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: clamp(1.5rem, 4vw, 3rem); align-items: center; }
  .atitle { font-size: clamp(2.4rem, 7vw, 4.6rem); line-height: 1.08; }
  .atitle .am { position: relative; display: inline-block; color: var(--scarlet-d); }
  .draw-line.under { position: absolute; left: -1%; bottom: -.1em; width: 102%; height: .2em; overflow: visible; }
  .draw-line.under path { fill: none; stroke: var(--amber); stroke-width: 8; stroke-linecap: round; }
  .alead { margin-top: 1.3rem; font-weight: 700; font-size: clamp(.98rem, 2vw, 1.2rem); line-height: 2; }
  .alead b { border-bottom: 3px solid var(--amber); }

  /* --- 案内うまくん：琥珀スプラッシュ --- */
  .portrait { position: relative; min-height: clamp(300px, 34vw, 440px); display: grid; place-items: center; }
  .p-splash { position: absolute; inset: -3% 0 0; width: 100%; height: 103%; }
  .p-splash path { fill: var(--amber); opacity: .9; }
  .p-swoosh { position: absolute; inset: -6% auto auto 58%; width: 42%; height: 30%; transform: rotate(14deg); }
  .p-swoosh path { fill: var(--ink); opacity: .13; }
  .avatar {
    position: relative; z-index: 2; width: min(72%, 330px);
    filter: drop-shadow(3px 5px 5px rgba(27,42,74,.2));
    animation: bob 3.2s ease-in-out infinite;
  }
  @keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }

  .cf { position: absolute; width: 13px; height: 13px; border-radius: 2px; z-index: 3; }
  .cf.c1 { top: 4%; left: 14%; background: var(--scarlet); transform: rotate(22deg); }
  .cf.c2 { top: 12%; right: 10%; background: var(--ink); transform: rotate(-16deg); width: 9px; height: 9px; }
  .cf.c3 { bottom: 14%; left: 6%; background: var(--amber-l); transform: rotate(12deg); width: 10px; height: 10px; }
  .cf.c4 { bottom: 5%; right: 20%; background: var(--scarlet); transform: rotate(-30deg); width: 10px; height: 10px; }
  .cf.c5 { top: 44%; right: 1%; background: var(--amber-d); transform: rotate(38deg); width: 9px; height: 9px; }

  .p-hello {
    position: absolute; z-index: 4; top: 8%; left: 3%;
    background: var(--card); border: 2.5px solid var(--ink); border-radius: 16px 16px 16px 4px;
    padding: .35rem .8rem; font-size: 1rem; box-shadow: var(--sh-2); rotate: -3deg;
  }
  .p-hello::after { content: ''; position: absolute; left: 18px; bottom: -11px; border: 6px solid transparent; border-top: 8px solid var(--ink); }
  .hanko-mini {
    position: absolute; z-index: 4; right: 6%; bottom: 6%;
    width: 40px; height: 40px; display: grid; place-items: center;
    font-family: var(--f-round); font-weight: 700; color: #fff; background: var(--scarlet);
    border-radius: 50%; rotate: -9deg;
    box-shadow: inset 0 0 0 2.5px rgba(255,255,255,.4), 1px 2px 4px rgba(27,42,74,.18);
  }

  /* --- 基本情報＝画鋲メモ --- */
  .facts-block { margin-top: clamp(2rem, 5vw, 3.2rem); }
  .facts-label { position: relative; display: inline-block; color: var(--scarlet-d); font-size: 1.08rem; rotate: -2deg; padding-right: 2.5rem; margin-bottom: .9rem; }
  .f-arrow { position: absolute; right: 0; top: .45rem; width: 34px; height: 24px; }
  .f-arrow path, .u-arrow path { fill: none; stroke: var(--scarlet-d); stroke-width: 2.2; stroke-linecap: round; }

  .facts { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.1rem .9rem; }
  .fact {
    position: relative; background: #FFFDF6; border-radius: 5px;
    padding: 1.05rem 1.1rem .85rem;
    box-shadow: 3px 5px 12px rgba(27,42,74,.14);
    rotate: -1.1deg;
    transition: rotate .25s var(--spring), translate .2s var(--spring), box-shadow .2s ease;
  }
  .fact:nth-child(even) { rotate: 1.2deg; }
  .fact:hover { rotate: 0deg; translate: 0 -4px; box-shadow: 5px 9px 16px rgba(27,42,74,.18); }
  .fact .pin {
    position: absolute; top: -8px; left: 50%; transform: translateX(-50%);
    width: 16px; height: 16px; border-radius: 50%;
    background: radial-gradient(circle at 34% 30%, #ff8f70, var(--scarlet) 60%, var(--scarlet-d));
    box-shadow: 0 3px 5px rgba(0,0,0,.25);
  }
  .fact:nth-child(even) .pin { background: radial-gradient(circle at 34% 30%, #ffdda6, var(--amber) 60%, var(--amber-d)); }
  .fact .fk { display: block; font-family: var(--f-hand); font-size: .92rem; color: var(--scarlet-d); }
  .fact .fv { font-weight: 700; line-height: 1.55; display: block; margin-top: .1rem; }

  /* --- 二面性 --- */
  .duo-grid { margin-top: 1.8rem; display: grid; grid-template-columns: 1fr auto 1fr; align-items: stretch; gap: clamp(1rem, 3vw, 2rem); }
  .panel {
    position: relative; background: var(--card); border: 2px solid var(--ink); border-radius: var(--r-lg);
    padding: 2rem 1.6rem 1.6rem; box-shadow: var(--sh-2); rotate: -.7deg;
    transition: rotate .25s var(--spring), translate .2s var(--spring), box-shadow .2s ease;
  }
  .panel.sell { rotate: .7deg; border-color: var(--scarlet); }
  .panel:hover { rotate: 0deg; translate: 0 -6px; box-shadow: var(--sh-3); }
  .panel .tape.red { background: color-mix(in oklab, var(--scarlet) 30%, #fff 40%); transform: translateX(-50%) rotate(3deg); }
  .panel .ic {
    display: grid; place-items: center; width: 56px; height: 56px; border-radius: 50%;
    font-size: 1.7rem; background: color-mix(in oklab, var(--amber) 22%, var(--paper));
  }
  .panel.sell .ic { background: color-mix(in oklab, var(--scarlet) 14%, var(--paper)); }
  .panel h3 { font-size: 1.4rem; margin: .6rem 0 .5rem; }
  .panel p { color: var(--mut); font-weight: 500; }
  .amp {
    align-self: center; width: 58px; height: 58px; display: grid; place-items: center;
    font-family: var(--f-round); font-weight: 900; font-size: 1.6rem; color: #fff;
    background: var(--scarlet); border-radius: 50%; rotate: -8deg;
    box-shadow: inset 0 0 0 2.5px rgba(255,255,255,.4), 2px 3px 6px rgba(27,42,74,.22);
  }

  /* --- 諦めない物語（一番の見せ場） --- */
  .story {
    background: var(--paper-2);
    border-block: 2px dashed color-mix(in oklab, var(--amber) 36%, var(--paper-3));
  }
  .story .am { position: relative; display: inline-block; color: var(--amber-d); }
  .draw-line.s-under { position: absolute; left: 0; bottom: -.14em; width: 100%; height: .18em; overflow: visible; }
  .draw-line.s-under path { fill: none; stroke: var(--scarlet); stroke-width: 6; stroke-linecap: round; opacity: .8; }
  .story .lead { margin-top: .5rem; font-weight: 700; }

  .ba { margin-top: 2.2rem; display: grid; grid-template-columns: 1fr auto 1.4fr; align-items: center; gap: clamp(1rem, 3vw, 2rem); }
  .ba-card { position: relative; background: var(--card); border: 2px solid var(--ink); border-radius: var(--r-lg); padding: 1.9rem 1.4rem 1.4rem; box-shadow: var(--sh-2); }
  .ba-card.before { background: var(--paper-3); border-color: var(--mut); rotate: -1deg; }
  .ba-card.after { rotate: .4deg; }
  .ba-card .tape.amber { background: color-mix(in oklab, var(--amber) 46%, #fff 26%); transform: translateX(-50%) rotate(3deg); }
  .ba-tag { font-family: var(--f-mono); font-size: .62rem; font-weight: 700; padding: .2rem .55rem; border-radius: var(--r-sm); background: var(--mut); color: var(--paper); }
  .ba-tag.on { background: var(--amber); color: #3a2606; }
  .ba-card h3 { font-size: 1.22rem; margin: .7rem 0 .5rem; }
  .ba-card p { color: var(--mut); font-weight: 500; font-size: .94rem; line-height: 1.85; }

  /* 赤ペンの書き込み */
  .circled { position: relative; display: inline-block; }
  .circled svg { position: absolute; inset: -30% -8%; width: 116%; height: 160%; overflow: visible; }
  .circled path { fill: none; stroke: var(--scarlet); stroke-width: 3; stroke-linecap: round; opacity: .85; }
  .redink { position: relative; display: inline-block; font-family: var(--f-hand); color: var(--scarlet); font-size: 1.1em; rotate: -1deg; padding: 0 .1em; }
  .scribble { position: absolute; left: 0; bottom: -.24em; width: 100%; height: .38em; overflow: visible; }
  .scribble path { fill: none; stroke: var(--scarlet); stroke-width: 2.4; stroke-linecap: round; opacity: .8; }

  .arrow { display: grid; justify-items: center; gap: .15rem; color: var(--scarlet-d); }
  .arrow svg { width: clamp(58px, 6vw, 84px); height: auto; }
  .arrow svg path { fill: none; stroke: var(--scarlet-d); stroke-width: 3; stroke-linecap: round; stroke-linejoin: round; }
  .arrow .hand { font-size: 1.04rem; rotate: -4deg; white-space: nowrap; }

  .ba .media { position: relative; border-radius: var(--r-md); overflow: hidden; margin: .8rem 0 .9rem; aspect-ratio: 16/10; background: var(--ink); }
  .ba .media video, .ba .media img { width: 100%; height: 100%; object-fit: cover; }
  .ba .badge { position: absolute; left: .6rem; bottom: .6rem; font-family: var(--f-mono); font-size: .62rem; font-weight: 700; background: var(--ink); color: var(--paper); padding: .28rem .55rem; border-radius: var(--r-sm); }

  .redink-note { position: relative; margin-top: 2rem; display: inline-block; font-family: var(--f-hand); font-size: clamp(1.05rem, 2.2vw, 1.3rem); color: var(--scarlet-d); rotate: -1deg; padding-bottom: .2em; }
  .redink-note .scribble path { stroke: var(--scarlet-d); }

  /* --- 売り子 --- */
  .uriko-grid { display: grid; grid-template-columns: .9fr 1.1fr; gap: clamp(2rem, 5vw, 4rem); align-items: center; }
  .uriko .am { color: var(--scarlet-d); white-space: nowrap; }
  .uriko-photo { position: relative; }
  .uriko-photo .ph {
    border-radius: 50% 46% 52% 48% / 52% 50% 50% 48%;
    overflow: hidden; border: 4px solid var(--ink); background: var(--paper-3);
    box-shadow: var(--sh-3); min-height: 300px; aspect-ratio: 4/4.4;
  }
  .uriko-photo .ph img { width: 100%; height: 100%; object-fit: cover; }
  .uriko-photo .tape { z-index: 3; }
  .uriko-photo .t1 { left: 18%; top: -4px; transform: rotate(-12deg); }
  .uriko-photo .t2 { left: 82%; top: 7%; transform: rotate(10deg); width: 78px; }
  .u-note { position: absolute; z-index: 3; top: -2.2rem; right: 2%; color: var(--scarlet-d); font-size: 1.06rem; rotate: 4deg; padding-left: 2.4rem; }
  .u-arrow { position: absolute; left: 0; top: .5rem; width: 32px; height: 24px; }
  .cheers {
    position: absolute; z-index: 4; right: -3%; bottom: -3%;
    width: clamp(104px, 12vw, 148px);
    filter: drop-shadow(3px 5px 5px rgba(27,42,74,.24));
    rotate: 6deg; transition: rotate .25s var(--spring), translate .25s var(--spring);
  }
