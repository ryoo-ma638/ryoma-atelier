---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { works } from '../data/works.ts';
import Calendar from '../components/Calendar.astro';

const kama = works.find((w) => w.slug === 'death-comer');

const facts = [
  { k: '名前', v: '大崎稜馬（おおさき りょうま）' },
  { k: '学び', v: '愛知工業大学 情報科学部 メディア情報専攻・3年' },
  { k: '研究室', v: '水野慎士研究室（CG・画像処理・インタラクション）' },
  { k: 'サークル', v: 'CEED（シード）副部長' },
  { k: 'もう一つの顔', v: 'バンテリンドームのビール売り子（自己プロデュース）' },
  { k: '性格', v: '愛嬌がある・元気・まっすぐ・諦めない' },
];
const skills = [
  { g: 'つくる（CG・画像処理）', items: ['C++ / OpenGL', 'OpenCV', 'Maya', 'LiDAR / センサー'] },
  { g: 'つくる（Web・アプリ）', items: ['Astro / TypeScript', 'HTML / CSS / JS', 'Firebase', 'Vercel'] },
  { g: 'つたえる（企画・発表）', items: ['スライド制作', 'イベント企画', 'グラフィック / ロゴ'] },
];
---
<Base title="ぼく ― 稜馬のアトリエ" description="大崎稜馬について。つくる人で、バンテリンドームのビール売り子。諦めずに、あたたかい作品をつくります。">
  <Nav />
  <main id="main">
    <!-- ===== イントロ ===== -->
    <header class="ahero">
      <div class="wrap intro-grid">
        <div>
          <p class="eyebrow"><span class="dot"></span>ABOUT · ぼくのこと</p>
          <h1 class="atitle">つくる人で、<br /><span class="am">ビール売り子。</span></h1>
          <p class="alead">
            大崎稜馬です。愛知工業大学でCGと画像処理をつくってる3年生。<br />
            「これだ」と思ったら、動くまで諦めません。<br />
            <b>作品も、ビールも、自分の手で人に手渡す</b>のが好きです。
          </p>
        </div>
        <div class="portrait">
          <img class="avatar" src="/assets/mascot/wave.png" alt="案内役のうまくん" />
          <span class="hanko-mini" aria-hidden="true">馬</span>
        </div>
      </div>

      <div class="wrap facts">
        {facts.map((f) => (
          <div class="fact reveal">
            <span class="fk">{f.k}</span>
            <span class="fv">{f.v}</span>
          </div>
        ))}
      </div>
    </header>

    <!-- ===== 二面性 ===== -->
    <section class="section duo">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>01 — ふたつの顔</p>
        <div class="duo-grid">
          <article class="panel reveal d1"><span class="ic">🛠️</span><h3>つくる人</h3><p>CG・画像処理・Web・ゲーム。水野研究室で、手を動かしてつくる。「動かない」で終わらせず、原因を突き止めて作り直す。</p></article>
          <span class="amp" aria-hidden="true">×</span>
          <article class="panel sell reveal d2"><span class="ic">🍺</span><h3>ビール売り子</h3><p>バンテリンドームで、自分をプロデュースして売る。届け方まで自分ごと。現場の熱と、まっすぐな声かけが武器。</p></article>
        </div>
      </div>
    </section>

    <!-- ===== 諦めなかった一本（鎌ゲーム） ===== -->
    <section class="section story">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>02 — 諦めなかった一本</p>
        <h2 class="big reveal d1">動かなかった。<span class="am">だから、作り直した。</span></h2>
        <p class="lead reveal d2">{kama?.title}</p>

        <div class="ba">
          <article class="ba-card before reveal d1">
            <span class="ba-tag">BEFORE</span>
            <h3>発表で、動かなかった。</h3>
            <p>デジコン演習(2025)で発表 ―― LiDARと鎌のセンサーで全身操作する設置型ゲーム。でも本番、思うように動かなかった。<span class="redink">＝ここで諦めない。</span></p>
          </article>

          <span class="arrow" aria-hidden="true">→</span>

          <article class="ba-card after reveal d2">
            <span class="ba-tag on">AFTER</span>
            <div class="media">
              {kama?.video
                ? <video src={kama.video} muted loop playsinline preload="none" poster={kama.thumb}></video>
                : <img src={kama?.thumb} alt={kama?.title} />}
              <span class="badge">開発中 · 水野研で再設計</span>
            </div>
            <h3>原因は“コードの調整”だった。</h3>
            <p>ハードのせいだと思い込まず、精読で原因を突き止めた。向きの一本化・防御のノイズ対策・デバッグ表示…と直し続け、いまも研究として継続開発中。</p>
          </article>
        </div>

        <p class="redink-note reveal">✎ 「これだ」と思ったものは、動くまでやめない。それがぼくの作り方です。</p>
      </div>
    </section>

    <!-- ===== 売り子 ===== -->
    <section class="section uriko">
      <div class="wrap uriko-grid">
        <div class="uriko-photo">
          <img src="/assets/photo/hero.jpg" alt="バンテリンドームのビール売り子（イメージ）" />
        </div>
        <div>
          <p class="eyebrow reveal"><span class="dot"></span>03 — もう一つの現場</p>
          <h2 class="big reveal d1">ドームで、<span class="am">まっすぐ売る。</span></h2>
          <p class="lead reveal d2">バンテリンドームのビール売り子。ただ売るんじゃなくて、自分をプロデュースして、笑顔と一緒に手渡す。人に届けることの楽しさは、ものづくりと地続きです。</p>
        </div>
      </div>
    </section>

    <!-- ===== 売り子カレンダー ===== -->
    <Calendar />

    <!-- ===== できること ===== -->
    <section class="section skills">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>04 — できること</p>
        <div class="skill-grid">
          {skills.map((s) => (
            <div class="skill reveal">
              <h3>{s.g}</h3>
              <ul>{s.items.map((it) => <li>{it}</li>)}</ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="wrap cta-row">
      <a class="btn" href="/works">作品を見る →</a>
      <a class="btn ghost" href="mailto:osaki638ryoma@gmail.com">声かけて ✉️</a>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .ahero { padding-top: clamp(2rem, 6vw, 4rem); }
  .intro-grid { display: grid; grid-template-columns: 1.1fr .9fr; gap: clamp(1.5rem, 4vw, 3rem); align-items: center; }
  .atitle { font-size: clamp(2.4rem, 7vw, 4.6rem); }
  .atitle .am { color: var(--scarlet-d); }
  .alead { margin-top: 1.2rem; font-weight: 700; font-size: clamp(1rem, 2vw, 1.2rem); }
  .alead b { border-bottom: 3px solid var(--amber); }

  .portrait, .uriko-photo { position: relative; border-radius: 50% 46% 52% 48% / 52% 50% 50% 48%; min-height: 300px; box-shadow: var(--sh-3); }
  .portrait { border: 3px solid var(--amber); background: radial-gradient(circle at 50% 42%, var(--paper-2), var(--paper-3)); display: grid; place-items: center; }
  .portrait .avatar { width: 76%; height: auto; filter: drop-shadow(3px 5px 5px rgba(27,42,74,.18)); }
  .uriko-photo { border: 4px solid var(--ink); overflow: hidden; background: var(--paper-3); }
  .uriko-photo img { width: 100%; height: 100%; object-fit: cover; }
  .hanko-mini { position: absolute; right: 10%; bottom: 8%; width: 34px; height: 34px; display: grid; place-items: center; font-family: var(--f-round); font-weight: 700; color: #fff; background: var(--scarlet); border-radius: 24% 26% 22% 28%; transform: rotate(-8deg); }

  .facts { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: .8rem; margin-top: 2.5rem; }
  .fact { background: var(--card); border: 2px solid var(--ink); border-radius: var(--r-md); padding: .9rem 1.1rem; box-shadow: var(--sh-1); }
  .fact .fk { display: block; font-family: var(--f-mono); font-size: .62rem; letter-spacing: .1em; color: var(--amber-d); }
  .fact .fv { font-weight: 700; }

  /* 二面性 */
  .duo-grid { margin-top: 1.6rem; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: clamp(1rem, 3vw, 2rem); }
  .panel { background: var(--card); border: 2px solid var(--ink); border-radius: var(--r-lg); padding: 1.6rem 1.5rem; box-shadow: var(--sh-2); }
  .panel .ic { font-size: 2rem; }
  .panel h3 { font-size: 1.4rem; margin: .4rem 0 .5rem; }
  .panel p { color: var(--mut); font-weight: 500; }
  .panel.sell { border-color: var(--scarlet); }
  .amp { font-size: 2rem; font-weight: 900; color: var(--amber-d); }

  /* 諦めない物語 */
  .story .am { color: var(--amber-d); }
  .ba { margin-top: 2rem; display: grid; grid-template-columns: 1fr auto 1.3fr; align-items: center; gap: clamp(1rem, 3vw, 2rem); }
  .ba-card { background: var(--card); border: 2px solid var(--ink); border-radius: var(--r-lg); padding: 1.4rem; box-shadow: var(--sh-2); }
  .ba-card.before { background: var(--paper-3); }
  .ba-tag { font-family: var(--f-mono); font-size: .62rem; font-weight: 700; padding: .2rem .55rem; border-radius: var(--r-sm); background: var(--mut); color: var(--paper); }
  .ba-tag.on { background: var(--amber); color: #3a2606; }
  .ba-card h3 { font-size: 1.2rem; margin: .7rem 0 .5rem; }
  .ba-card p { color: var(--mut); font-weight: 500; font-size: .92rem; }
  .redink { color: var(--scarlet); font-weight: 700; }
  .ba .media { position: relative; border-radius: var(--r-md); overflow: hidden; margin-bottom: .8rem; aspect-ratio: 16/10; background: var(--ink); }
  .ba .media video, .ba .media img { width: 100%; height: 100%; object-fit: cover; }
  .ba .badge { position: absolute; left: .6rem; bottom: .6rem; font-family: var(--f-mono); font-size: .6rem; font-weight: 700; background: var(--ink); color: var(--paper); padding: .25rem .5rem; border-radius: var(--r-sm); }
  .arrow { font-size: 2rem; font-weight: 900; color: var(--amber-d); }
  .redink-note { margin-top: 1.6rem; font-family: var(--f-round); font-weight: 700; color: var(--scarlet-d); transform: rotate(-1deg); display: inline-block; }

  /* 売り子 */
  .uriko-grid { display: grid; grid-template-columns: .9fr 1.1fr; gap: clamp(1.5rem, 4vw, 3rem); align-items: center; }
  .uriko .am { color: var(--scarlet-d); }

  /* skills */
  .skill-grid { margin-top: 1.6rem; display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; }
  .skill { background: var(--card); border: 2px solid var(--ink); border-radius: var(--r-md); padding: 1.2rem 1.3rem; box-shadow: var(--sh-1); }
  .skill h3 { font-size: 1.05rem; margin-bottom: .7rem; }
  .skill ul { list-style: none; display: flex; flex-wrap: wrap; gap: .4rem; }
  .skill li { font-family: var(--f-mono); font-size: .68rem; padding: .25rem .55rem; border-radius: var(--r-sm); background: var(--paper-3); }

  .cta-row { display: flex; gap: 1rem; margin-top: 1rem; flex-wrap: wrap; }

  @media (max-width: 820px) {
    .intro-grid, .uriko-grid { grid-template-columns: 1fr; }
    .duo-grid, .ba { grid-template-columns: 1fr; }
    .amp, .arrow { transform: rotate(90deg); justify-self: center; }
    .uriko-photo { order: 2; }
  }
</style>
