---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { works } from '../data/works.ts';
import Calendar from '../components/Calendar.astro';

const kama = works.find((w) => w.slug === 'death-comer');

const facts = [
  { k: '名前', v: '大崎稜馬（おおさき りょうま）' },
  { k: '学び', v: '愛知工業大学 情報科学部 メディア情報専攻・3年' },
  { k: '研究室', v: '水野慎士研究室（CG・画像処理・インタラクション）' },
  { k: 'サークル', v: 'CEED（シード）副部長' },
  { k: 'もう一つの顔', v: 'バンテリンドームのビール売り子（自己プロデュース）' },
  { k: '性格', v: '愛嬌がある・元気・まっすぐ・諦めない' },
];
const skills = [
  { g: 'つくる（CG・画像処理）', icon: '🖥️', color: 'var(--c-violet)', items: ['C++ / OpenGL', 'OpenCV', 'Maya', 'LiDAR / センサー'] },
  { g: 'つくる（Web・アプリ）', icon: '📱', color: 'var(--c-blue)', items: ['Astro / TypeScript', 'HTML / CSS / JS', 'Firebase', 'Vercel'] },
  { g: 'えがく・うつす', icon: '🎨', color: 'var(--c-red)', items: ['Illustrator', 'Photoshop', 'Premiere Pro', 'ロゴ・ポスター'] },
  { g: 'つたえる（企画・発表）', icon: '📣', color: 'var(--c-green)', items: ['スライド制作', 'イベント企画', '発表・プレゼン'] },
];

// これまでの話（2006→これから）。ドットの色＝出せる色が増えていく。※Vol.1から継承（事実）
const timeline = [
  { num: '2006', tag: '誕生', title: '名古屋に生まれる', text: '1月1日、名古屋市で生まれる。', c: 'var(--c-violet)' },
  { num: '2012', tag: '小学校時代', title: 'ムードメーカー、そして児童会長', text: 'クラスを明るくする盛り上げ役。児童会長を務め、人をまとめ、場をつくる楽しさを知る。', c: 'var(--c-blue)' },
  { num: '2018', tag: '中学校時代', title: '野球と、生徒会長', text: '野球チームに所属。生徒会長として学校を盛り上げ、リーダーとしての土台をつくる。', c: 'var(--c-cyan)' },
  { num: '2021', tag: '高校時代', title: '学業に励んだ3年間', text: '進路を見据えながら、3年間しっかりと学業に打ち込む。', c: 'var(--c-green)' },
  { num: '2024', tag: '大学入学', title: '愛知工業大学 情報科学部へ', text: '情報科学部に入学（コンピュータシステム専攻）。', c: 'var(--c-yellow)' },
  { num: '2025', tag: '転機', title: '転専攻、そしてCEED', text: 'ものづくりへの興味から、メディア情報専攻へ転専攻。マルチクリエイティブサークルCEEDに所属する。', c: 'var(--c-orange)' },
  { num: '2026', tag: '現在', title: '研究室と、副部長', text: '水野慎士研究室（CGメディア）でCG・画像処理を専門に。CEED副部長として60名規模のサークル運営を支えている。', c: 'var(--c-red)' },
  { num: 'これから', tag: 'FUTURE', title: 'つくって、手渡す。', text: 'いろんなことに挑戦したい。人生は一度きりだから、後悔のないよう、たくさんの壁を越えていく。', c: 'var(--amber-d)', future: true },
];

// 信条（座右の銘・尊敬する人・原点・流儀）— すべて本人の言葉
const motto = { word: '「謙虚」', reason: '中学の野球部時代に、繰り返し言われてきた言葉。尊敬する大先輩・栗林良吏選手（広島東洋カープ）が大切にしている言葉でもある。' };
const credo = [
  { tag: '尊敬する人', title: '戸塚優斗選手（スノーボード）', text: '2026年の冬季オリンピック金メダリスト。怪我を乗り越えて挑み続けるその姿に、勇気をもらった。自分も頑張ろう、と思える存在。' },
  { tag: 'ものづくりの原点', title: '「やりたい」に、突き進む', text: '「自分がやりたい」という気持ちに、ただ突き進んできた。その積み重ねが、今の自分をつくっている。' },
  { tag: '制作の流儀', title: '満足するまで、諦めない', text: '自分を、作品を客観視する。厳しい評価を受け止めてから、納得のいくものに仕上がるまで徹底的に。最後は根気と、根性。' },
];

// 一問一答（人となり）
const qa = [
  { q: '一言で言うと', a: '真面目バカ。' },
  { q: '好きな映画', a: '『スター・ウォーズ』『バック・トゥ・ザ・フューチャー』。感性に、新しい気づきとひらめきをくれた。' },
  { q: '好きなドラマ', a: '『ROOKIES（ルーキーズ）』。' },
  { q: '中日の推し', a: '捕手・加藤匠馬選手。かつては堂上直倫選手。' },
  { q: '推しのきっかけ', a: 'TBS『ラヴィット！』で弓木奈於さんの面白さと可愛らしさに惹かれ、乃木坂46の虜に。' },
  { q: '休日', a: '寝る。推し活。新しいことに挑戦する。つくりたいものをつくる。' },
  { q: '好きな食べ物', a: '餃子・お寿司・焼肉。' },
  { q: '落ち着く場所', a: '家。' },
];

// 取扱説明書（友人の評価より）
const traits = [
  { t: '好きなものに一直線', d: '「好き」と決めたものに、最上級の熱を注ぐ。', c: 'var(--c-violet)' },
  { t: '行動力のかたまり', d: '飛び込む勇気が強い。転専攻でも、友達をつくってやり切る。', c: 'var(--c-blue)' },
  { t: 'こだわりが強い', d: '納得いくまで加筆・修正。自分のセンスと価値観で、ものをつくる。', c: 'var(--c-cyan)' },
  { t: '“見せるもの”で輝く', d: '人に見せる制作になると、本気のギアが入る。実際、選ばれることも多い。', c: 'var(--c-green)' },
  { t: '裏表がない', d: '喜怒哀楽が全部、顔に出る。リアクションが大きくて面白い。', c: 'var(--c-yellow)' },
  { t: '猪突猛進', d: '関わることに全力。一生懸命で、元気いっぱい。', c: 'var(--c-orange)' },
  { t: '基本、やさしい', d: '頼まれごとは、大抵引き受ける。', c: 'var(--c-red)' },
  { t: '人懐っこい', d: 'すぐ人に近づいて話しかける。元気な犬みたい。', c: 'var(--c-violet)' },
];

// 主な実績（すべて事実・ガクチカ準拠）
const highlights = [
  { n: '60名', l: '規模のサークル', d: 'CEED副部長として「誰も置いてけぼりにしない」運営を支え、サークルは60名規模のコミュニティに成長。', href: '/ceed' },
  { n: '企業賞', l: 'ハッカソン', d: 'シスハックで割り勘アプリ「Settlo」を開発し、企業賞を受賞。', href: '/works/settlo' },
  { n: '出展', l: 'TGS ほか', d: '体感型ゲーム「虫歯アニマルズ」をデザイン・造形で担当。東京ゲームショウ・ゲームマーケット・安城Eフェスで出展。', href: '/works/mushiba-animals' },
  { n: '接客', l: 'ビール売り子', d: 'バンテリンドームナゴヤで、ビールの売り子として活動。「応援したくなる接客」を工夫している。', href: '/works/uriko-site' },
];
---
<Base title="ぼく ― 稜馬のアトリエ" description="大崎稜馬について。つくる人で、バンテリンドームのビール売り子。諦めずに、あたたかい作品をつくります。">
  <Nav />
  <main id="main">
    <!-- ===== イントロ ===== -->
    <header class="ahero">
      <div class="wrap intro-grid">
        <div class="intro-copy">
          <p class="eyebrow"><span class="dot"></span>ABOUT · ぼくのこと</p>
          <h1 class="atitle">つくる人で、<br /><span class="am">ビール売り子。
            <svg class="draw-line under" viewBox="0 0 340 18" preserveAspectRatio="none" aria-hidden="true" style="--len:360">
              <path d="M6,12 C70,4 130,16 190,9 C240,3 300,14 334,7" />
            </svg>
          </span></h1>
          <p class="arole">
            大崎稜馬（おおさき りょうま）。<br />
            愛知工業大学 情報科学部 情報科学科 メディア情報専攻／<b>水野慎士研究室</b>。<br />
            CG・画像処理・Web・映像・グラフィック・企画を横断してつくっています。
          </p>
          <p class="alead">
            ひとつの専門に絞らず、面白いと思ったものに片っ端から手を出してきました。
            <b>手を広げるほど、出せる色が増えていく</b>——そう信じて、つくり続けています。<br />
            「これだ」と思ったら、動くまで諦めません。
            <span class="warm">作品も、ビールも、自分の手で人に手渡すのが好きです。</span>
          </p>
        </div>

        <!-- 本人の実写＋うまくん -->
        <div class="portrait">
          <svg class="p-splash" viewBox="0 0 640 560" preserveAspectRatio="none" aria-hidden="true">
            <path d="M120,540 C40,470 60,380 140,330 C90,260 130,160 230,130 C250,60 350,20 440,50 C520,10 610,60 620,150 C660,240 600,330 520,360 C520,440 440,510 340,500 C270,560 170,580 120,540 Z" />
          </svg>
          <span class="cf c1" aria-hidden="true"></span><span class="cf c2" aria-hidden="true"></span>
          <span class="cf c3" aria-hidden="true"></span><span class="cf c4" aria-hidden="true"></span>
          <span class="cf c5" aria-hidden="true"></span>
          <figure class="p-photo">
            <img src="/assets/about/portrait.jpg" alt="大崎稜馬のポートレート" data-gallery='["/assets/about/portrait.jpg"]' data-caption="大崎 稜馬 — Osaki Ryoma" />
          </figure>
          <img class="avatar-mini" src="/assets/mascot/wave.png" alt="" aria-hidden="true" data-confetti-click="30" />
          <span class="p-hello hand">ようこそ！</span>
          <span class="hanko-mini" aria-hidden="true">馬</span>
        </div>
      </div>

      <div class="wrap facts-block">
        <p class="facts-label hand">ぼくの基本情報
          <svg class="f-arrow" viewBox="0 0 46 30" aria-hidden="true"><path d="M6,4 C16,18 26,24 40,26 M40,26 l-9,-3 M40,26 l-1,-9" /></svg>
        </p>
        <div class="facts">
          {facts.map((f, i) => (
            <div class={`fact reveal d${(i % 3) + 1}`}>
              <span class="pin" aria-hidden="true"></span>
              <span class="fk">{f.k}</span>
              <span class="fv">{f.v}</span>
            </div>
          ))}
        </div>
      </div>
    </header>

    <!-- ===== 二面性 ===== -->
    <section class="section duo">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>01 — ふたつの顔</p>
        <div class="duo-grid">
          <article class="panel reveal d1">
            <span class="tape" aria-hidden="true"></span>
            <span class="ic" aria-hidden="true">🛠️</span>
            <h3>つくる人</h3>
            <p>CG・画像処理・Web・ゲーム。水野研究室で、手を動かしてつくる。「動かない」で終わらせず、原因を突き止めて作り直す。</p>
          </article>
          <span class="amp" aria-hidden="true"><b>×</b><i class="hand">かける</i></span>
          <article class="panel sell reveal d2">
            <span class="tape red" aria-hidden="true"></span>
            <span class="ic" aria-hidden="true">🍺</span>
            <h3>ビール売り子</h3>
            <p>バンテリンドームで、自分をプロデュースして売る。届け方まで自分ごと。現場の熱と、まっすぐな声かけが武器。</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ===== これまでの、話。（年表） ===== -->
    <section class="section tl-sec">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>02 — これまでの、話。</p>
        <h2 class="big reveal d1">名古屋のムードメーカーから、<span class="am">つくる人へ。</span></h2>
        <p class="lead reveal d2">出せる色は、すこしずつ増えてきた。</p>
        <ol class="tl">
          {timeline.map((t, i) => (
            <li class={`tl-item reveal d${(i % 3) + 1}${t.future ? ' future' : ''}`} style={`--c:${t.c}`}>
              <span class="tl-dot" aria-hidden="true"></span>
              <span class="tl-num">{t.num}</span>
              <div class="tl-body">
                <span class="tl-tag">{t.tag}</span>
                <h3>{t.title}</h3>
                <p>{t.text}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ===== 信条 ===== -->
    <section class="section credo-sec">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>03 — 信条</p>
        <div class="motto reveal d1">
          <span class="tape" aria-hidden="true"></span>
          <span class="m-label hand">座右の銘</span>
          <p class="m-word">{motto.word}</p>
          <p class="m-reason">{motto.reason}</p>
        </div>
        <div class="credo-grid">
          {credo.map((c, i) => (
            <article class={`credo reveal d${i + 1}`}>
              <span class="c-tag">{c.tag}</span>
              <h3>{c.title}</h3>
              <p>{c.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== 諦めなかった一本（鎌ゲーム） ===== -->
    <section class="section story">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>04 — 諦めなかった一本</p>
        <h2 class="big reveal d1">動かなかった。<span class="am">だから、作り直した。
          <svg class="draw-line s-under" viewBox="0 0 340 18" preserveAspectRatio="none" aria-hidden="true" style="--len:360">
            <path d="M6,12 C70,5 130,15 190,8 C240,4 300,13 334,6" />
          </svg>
        </span></h2>
        <p class="lead reveal d2">{kama?.title}</p>

        <div class="ba">
          <article class="ba-card before reveal d1">
            <span class="tape" aria-hidden="true"></span>
            <span class="ba-tag">BEFORE</span>
            <h3>発表で、<span class="circled">動かなかった<svg class="draw-line" viewBox="0 0 200 60" preserveAspectRatio="none" aria-hidden="true" style="--len:580"><path d="M14,30 C22,9 178,5 189,26 C195,47 32,57 15,40 C7,32 12,18 26,13" /></svg></span>。</h3>
            <p>デジコン演習(2025)で発表 ―― LiDARと鎌のセンサーで全身操作する設置型ゲーム。でも本番、思うように動かなかった。<span class="redink">＝ここで諦めない。<svg class="scribble" viewBox="0 0 160 12" preserveAspectRatio="none" aria-hidden="true"><path d="M4,8 C40,3 80,11 156,5" /></svg></span></p>
          </article>

          <span class="arrow reveal d2" aria-hidden="true">
            <svg viewBox="0 0 90 60"><path d="M6,12 C34,8 60,22 78,44 M78,44 l-14,-4 M78,44 l1,-14" /></svg>
            <span class="hand">作りなおす！</span>
          </span>

          <article class="ba-card after reveal d3">
            <span class="tape amber" aria-hidden="true"></span>
            <span class="ba-tag on">AFTER</span>
            <div class="media">
              {kama?.video
                ? <video data-autoplay src={kama.video} muted loop playsinline preload="none" poster={kama.thumb}></video>
                : <img src={kama?.thumb} alt={kama?.title} />}
              <span class="badge">開発中 · 水野研で再設計</span>
            </div>
            <h3>原因は“コードの調整”だった。</h3>
            <p>ハードのせいだと思い込まず、精読で原因を突き止めた。向きの一本化・防御のノイズ対策・デバッグ表示…と直し続け、いまも研究として継続開発中。</p>
          </article>
        </div>

        <p class="redink-note reveal">✎ 「これだ」と思ったものは、動くまでやめない。それがぼくの作り方です。
          <svg class="scribble" viewBox="0 0 300 12" preserveAspectRatio="none" aria-hidden="true"><path d="M4,8 C70,3 150,11 296,5" /></svg>
        </p>
      </div>
    </section>

    <!-- ===== 主な実績 ===== -->
    <section class="section hl-sec">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>05 — 主な実績</p>
        <div class="hls">
          {highlights.map((h, i) => (
            <a class={`hl reveal d${(i % 4) + 1}`} href={h.href}>
              <span class="hl-n">{h.n}</span>
              <span class="hl-l">{h.l}</span>
              <p>{h.d}</p>
              <span class="hl-go">くわしく →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== 売り子 ===== -->
    <section class="section uriko">
      <div class="wrap uriko-grid">
        <div class="uriko-photo reveal d1">
          <div class="ph"><img src="/assets/photo/hero.jpg" alt="バンテリンドームのビール売り子（イメージ）" /></div>
          <span class="tape t1" aria-hidden="true"></span>
          <span class="tape t2" aria-hidden="true"></span>
          <span class="u-note hand">現場のぼく！
            <svg class="u-arrow" viewBox="0 0 46 30" aria-hidden="true"><path d="M40,4 C30,18 20,24 6,26 M6,26 l9,-3 M6,26 l1,-9" /></svg>
          </span>
          <img class="cheers" src="/assets/mascot/cheers.png" alt="" aria-hidden="true" />
        </div>
        <div>
          <p class="eyebrow reveal"><span class="dot"></span>06 — もう一つの現場</p>
          <h2 class="big reveal d1">ドームで、<span class="am">まっすぐ売る。</span></h2>
          <p class="lead reveal d2">バンテリンドームのビール売り子。ただ売るんじゃなくて、自分をプロデュースして、笑顔と一緒に手渡す。人に届けることの楽しさは、ものづくりと地続きです。</p>
          <p class="u-chips reveal d3">
            <span>🍺 バンテリンドーム</span>
            <span>😊 自己プロデュース</span>
            <span>🤝 手渡しがすき</span>
          </p>
        </div>
      </div>
    </section>

    <!-- ===== 売り子カレンダー ===== -->
    <Calendar />

    <!-- ===== つくる以外の、わたし。 ===== -->
    <section class="section beyond">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>07 — つくる以外の、わたし。</p>
        <h2 class="big reveal d1">つくる原動力は、<span class="am">夢中になれる「好き」。</span></h2>
        <p class="lead reveal d2">盛り上げ役の血は、現場でも変わりません。</p>

        <div class="pcards">
          <figure class="pcard reveal d1">
            <span class="tape" aria-hidden="true"></span>
            <button class="pc-media" type="button" data-gallery='["/assets/about/baseball.jpg"]' data-caption="バンテリンドームナゴヤにて — 中日ドラゴンズを応援。">
              <img src="/assets/about/baseball.jpg" alt="バンテリンドームで中日ドラゴンズを応援する大崎稜馬" loading="lazy" style="object-position: 50% 42%" />
              <span class="pc-chip">⚾ 野球観戦</span>
            </button>
            <figcaption>
              <h3>中日ドラゴンズと、バンテリンドーム</h3>
              <p>生まれも育ちも名古屋。中日ドラゴンズのファンとして球場へ。推しは捕手の加藤匠馬選手（かつては堂上直倫選手）。スタンドで浴びる熱気が、明日への活力です。</p>
            </figcaption>
          </figure>

          <figure class="pcard reveal d2">
            <span class="tape t2" aria-hidden="true"></span>
            <button class="pc-media" type="button" data-gallery='["/assets/about/oshikatsu.jpg"]' data-caption="14th YEAR BIRTHDAY LIVE — 弓木奈於さんを応援。">
              <img src="/assets/about/oshikatsu.jpg" alt="ライブ会場でタオルを掲げて推し活をする大崎稜馬" loading="lazy" style="object-position: 50% 14%" />
              <span class="pc-chip">💜 推し活</span>
            </button>
            <figcaption>
              <h3>乃木坂46・弓木奈於さんの応援</h3>
              <p>『ラヴィット！』をきっかけに乃木坂46の虜に。応援する熱が高じて、ファンサイト「YUMIKI WORLD」を自作するほど。“好き”が、そのまま制作の原動力になりました。</p>
              <a class="pc-link" href="/works/yumiki-world">YUMIKI WORLD の話 →</a>
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- ===== もっと、知る。（一問一答＋取扱説明書） ===== -->
    <section class="section more">
      <div class="wrap">
        <p class="eyebrow reveal"><span class="dot"></span>08 — もっと、知る。</p>

