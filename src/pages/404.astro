---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Base title="みちに迷いました ― 稜馬のアトリエ" description="ページが見つかりませんでした。">
  <Nav />
  <main id="main">
    <section class="nf wrap">
      <p class="code" aria-hidden="true">4<span class="uma-o"><img src="/assets/mascot/logo3d.png" alt="" /></span>4</p>
      <h1>あれ？ このページ、見つかりません。</h1>
      <p class="hand note">うまくんが全力で探したけど、なかったみたい…。</p>
      <img class="runner" src="/assets/mascot/run.png" alt="" />
      <div class="acts">
        <a class="btn" href="/">トップへもどる →</a>
        <a class="btn ghost" href="/works">作品を見る →</a>
      </div>
    </section>
  </main>
  <Footer />
</Base>

<style>
  .nf { text-align: center; padding-block: clamp(3rem, 8vw, 6rem); }
  .code { font-weight: 900; font-size: clamp(5rem, 18vw, 11rem); line-height: 1; letter-spacing: .04em; color: var(--ink); display: flex; align-items: center; justify-content: center; gap: .06em; }
  .uma-o { display: inline-grid; place-items: center; width: .92em; height: .92em; }
  .uma-o img { width: 100%; height: 100%; object-fit: contain; animation: wobble 2.6s ease-in-out infinite; }
  @keyframes wobble { 0%, 100% { transform: rotate(-9deg); } 50% { transform: rotate(9deg); } }
  h1 { font-size: clamp(1.3rem, 3.4vw, 2rem); margin-top: 1rem; }
  .note { color: var(--scarlet-d); font-size: 1.1rem; margin-top: .7rem; transform: rotate(-1.2deg); display: inline-block; }
  .runner { width: min(240px, 55vw); margin: 1.6rem auto 0; filter: drop-shadow(4px 6px 6px rgba(27,42,74,.2)); animation: bob .6s ease-in-out infinite; }
  @keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-7px); } }
  .acts { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-top: 2rem; }
</style>
