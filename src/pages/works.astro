---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WorkCard from '../components/WorkCard.astro';
import { works, categoryLabels, type Category } from '../data/works.ts';

// 分野の並び（専門優先）。
const order: Category[] = ['web', 'imaging', 'cg', 'video', 'planning', 'graphic', 'sound'];
const groups = order
  .map((c) => ({ c, label: categoryLabels[c], items: works.filter((w) => w.category === c) }))
  .filter((g) => g.items.length);
const total = works.length;
---
<Base title="作品 ― 稜馬のアトリエ" description="大崎稜馬の作品一覧。CG・画像処理・Web・映像・企画・グラフィックを分野ごとに。">
  <Nav />
  <main id="main">
    <!-- ===== ページヘッダー ===== -->
    <header class="whero">
      <div class="wrap whead">
        <p class="eyebrow"><span class="dot"></span>WORKS · つくったもの</p>

        <div class="trow">
          <h1 class="wtitle">
            <span class="tin">作品
              <svg class="draw-line under" viewBox="0 0 250 20" preserveAspectRatio="none" aria-hidden="true" style="--len:280">
                <path d="M8,14 C55,5 105,17 150,10 C195,4 228,14 244,8" />
              </svg>
            </span>
            <span class="hanko" aria-hidden="true">馬</span>
          </h1>
          <span class="scribble hand" aria-hidden="true">
            <svg class="s-arrow" viewBox="0 0 40 26" aria-hidden="true"><path d="M36,6 C27,15 18,20 6,20 M6,20 l9,-6 M6,20 l10,2" /></svg>
            ぜんぶ、本気でつくった！
          </span>
        </div>

        <p class="wlead">「これだ」と思って、最後までつくったもの。<b>全{total}点</b>を分野ごとに並べています。</p>

        <nav class="jump" aria-label="分野で移動">
          {groups.map((g) => (
            <a href={`#cat-${g.c}`} style={`--tag:${g.label.color}`}>
              <span class="jd" aria-hidden="true"></span>{g.label.ja}<span class="jc">{g.items.length}</span>
            </a>
          ))}
        </nav>

        <!-- 余白の紙吹雪 -->
        <span class="cf f1" aria-hidden="true"></span>
        <span class="cf f2" aria-hidden="true"></span>
        <span class="cf f3" aria-hidden="true"></span>
        <span class="cf f4" aria-hidden="true"></span>
      </div>
    </header>

    <!-- ===== 分野ごとの一覧 ===== -->
    {groups.map((g, gi) => (
      <section class="cat section" id={`cat-${g.c}`} style={`--tag:${g.label.color}`}>
        <div class="wrap">
          <span class="ghost" aria-hidden="true" style={`font-size:min(${Math.min(7, 74 / g.label.en.length).toFixed(2)}rem, 9vw)`}>{g.label.en}</span>
          <h2 class="cat-head reveal">
            <span class="num">{String(gi + 1).padStart(2, '0')}</span>
            <span class="cja">{g.label.ja}</span>
            <span class="cen">{g.label.en}</span>
            <span class="ccnt"><b>{g.items.length}</b><small>作品</small></span>
          </h2>
          <svg class="rule draw-line" viewBox="0 0 1180 14" preserveAspectRatio="none" aria-hidden="true" style="--len:1210">
            <path d="M6,9 C150,3 290,12 440,7 C600,2 760,11 920,6 C1030,3 1120,9 1174,6" />
          </svg>

          <div class="grid">
            {g.items.map((w, i) => <WorkCard work={w} i={i} />)}
          </div>

          {g.c === 'web' && (
            <aside class="ynote reveal d2">
              <span class="pin" aria-hidden="true"></span>
              <p>弓木さんの推しサイト「YUMIKI WORLD」は、<b>著作権・肖像権に配慮した非公式ファンサイト</b>としてWeb作品に入れています。</p>
            </aside>
          )}
        </div>
      </section>
    ))}
  </main>
  <Footer />
</Base>

<style>
  /* ===== ページヘッダー ===== */
  .whero { padding: clamp(2.4rem, 6.5vw, 4.6rem) 0 .6rem; }
  .whead { position: relative; }

  .trow { display: flex; align-items: flex-end; gap: clamp(1.6rem, 4vw, 3.2rem); flex-wrap: wrap; }
  .wtitle { font-size: clamp(3rem, 11vw, 6.6rem); line-height: 1.05; position: relative; display: inline-flex; }
  .wtitle .tin { position: relative; display: inline-block; }
  .draw-line.under { position: absolute; left: -2%; bottom: -.1em; width: 104%; height: .2em; overflow: visible; }
  .draw-line.under path { fill: none; stroke: var(--amber); stroke-width: 9; stroke-linecap: round; }
  .wtitle .hanko {
    position: absolute; top: -.02em; right: -.85em;
    width: 1em; height: 1em; display: grid; place-items: center;
    font-family: var(--f-round); font-weight: 700; font-size: .3em; color: #fff;
    background: var(--scarlet); border-radius: 26% 24% 28% 22%;
    transform: rotate(-8deg);
    box-shadow: inset 0 0 0 3px rgba(255,255,255,.35), 1px 2px 4px rgba(27,42,74,.18);
  }

  /* 手書きの一言（判子のとなり） */
  .scribble {
    position: relative; color: var(--scarlet-d);
    font-size: clamp(1rem, 2.4vw, 1.3rem); line-height: 1.3;
    transform: rotate(2.5deg); padding-bottom: clamp(.6rem, 2vw, 1.4rem);
    display: inline-flex; align-items: center; gap: .35rem;
  }
  .s-arrow { width: 36px; height: 24px; flex: 0 0 auto; }
  .s-arrow path { fill: none; stroke: var(--scarlet-d); stroke-width: 2.2; stroke-linecap: round; }

  .wlead { margin-top: 1.1rem; font-size: clamp(1rem, 2.2vw, 1.25rem); font-weight: 700; }
  .wlead b { color: var(--amber-d); }

  /* 分野ジャンプ（色ドット付きピル） */
  .jump { display: flex; flex-wrap: wrap; gap: .6rem; margin-top: 1.7rem; }
  .jump a {
    display: inline-flex; align-items: center; gap: .45rem;
    font-family: var(--f-round); font-weight: 700; font-size: .9rem;
    padding: .48rem .95rem; border-radius: var(--r-pill);
    background: var(--card); border: 2px solid var(--ink);
    box-shadow: 0 3px 0 color-mix(in oklab, var(--ink) 30%, var(--paper-3));
    transition: transform .16s var(--spring), background .2s ease, box-shadow .16s ease;
  }
  .jump a:hover {
    transform: translateY(-3px) rotate(-1deg);
    background: color-mix(in oklab, var(--tag) 12%, var(--card));
    box-shadow: 0 6px 0 color-mix(in oklab, var(--ink) 30%, var(--paper-3));
  }
  .jump a:active { transform: translateY(1px); box-shadow: 0 1px 0 color-mix(in oklab, var(--ink) 30%, var(--paper-3)); }
  .jump .jd { width: 11px; height: 11px; border-radius: 50%; background: var(--tag); box-shadow: inset 0 0 0 2px color-mix(in oklab, #fff 45%, transparent); }
  .jump .jc {
    font-family: var(--f-mono); font-size: .66rem; font-weight: 700; color: var(--ink);
    background: color-mix(in oklab, var(--tag) 18%, var(--paper));
    border-radius: var(--r-pill); padding: .06rem .42rem;
  }

  /* 余白の紙吹雪（ヘッダー右） */
  .cf { position: absolute; border-radius: 2px; pointer-events: none; }
  .cf.f1 { top: 8%; right: 7%; width: 13px; height: 13px; background: var(--amber); transform: rotate(24deg); }
  .cf.f2 { top: 38%; right: 15%; width: 9px; height: 9px; background: var(--scarlet); transform: rotate(-18deg); }
  .cf.f3 { top: 62%; right: 4%; width: 11px; height: 11px; background: var(--ink); opacity: .75; transform: rotate(40deg); }
  .cf.f4 { top: 20%; right: 24%; width: 8px; height: 8px; background: var(--amber-l); transform: rotate(-30deg); }

  /* ===== 分野セクション ===== */
  .cat { padding-block: clamp(2.4rem, 5.5vw, 4rem); scroll-margin-top: 84px; }

  .cat .wrap { position: relative; }
  /* 巨大ゴースト英字（分野の空気を出す・読みは邪魔しない） */
  .ghost {
    position: absolute; right: 0; top: -2.2rem; z-index: 0;
    font-family: var(--f-mono); font-weight: 700;
    letter-spacing: .02em; color: transparent; -webkit-text-stroke: 2px color-mix(in oklab, var(--tag) 26%, transparent);
    pointer-events: none; user-select: none; white-space: nowrap;
  }
  .cat-head { display: flex; align-items: baseline; gap: .85rem; flex-wrap: wrap; position: relative; z-index: 1; }
  .cat-head .num {
    font-family: var(--f-mono); font-size: 1.05rem; font-weight: 700;
    color: color-mix(in oklab, var(--tag) 80%, var(--ink));
    background: color-mix(in oklab, var(--tag) 13%, var(--paper));
    border: 1.5px solid color-mix(in oklab, var(--tag) 40%, transparent);
    border-radius: var(--r-sm); padding: .1rem .5rem;
    transform: translateY(-.15em) rotate(-2deg); align-self: center;
  }
  .cat-head .cja { font-size: clamp(1.6rem, 4.2vw, 2.4rem); font-weight: 900; letter-spacing: .01em; }
  .cat-head .cen { font-family: var(--f-mono); font-size: .7rem; color: var(--mut); letter-spacing: .14em; text-transform: uppercase; }

  /* 件数＝琥珀の丸バッジ */
  .cat-head .ccnt {
    margin-left: auto; align-self: center;
    width: 52px; height: 52px; border-radius: 50%;
    display: grid; place-content: center; text-align: center; line-height: 1;
    background: var(--amber); color: #3a2606;
    box-shadow: 0 3px 0 var(--amber-d), inset 0 0 0 2px rgba(255,255,255,.35);
    transform: rotate(7deg);
    transition: transform .2s var(--spring);
  }
  .cat-head:hover .ccnt { transform: rotate(-4deg) scale(1.06); }
  .cat-head .ccnt b { font-family: var(--f-round); font-weight: 900; font-size: 1.2rem; display: block; }
  .cat-head .ccnt small { font-family: var(--f-round); font-weight: 700; font-size: .54rem; letter-spacing: .05em; display: block; margin-top: .12rem; }

  /* 見出し下＝手描きマーカーの罫線 */
  .rule { display: block; width: 100%; height: 12px; margin: .35rem 0 1.9rem; overflow: visible; }
  .rule path { fill: none; stroke: var(--tag); stroke-width: 5; stroke-linecap: round; opacity: .9; }

  .grid { display: grid; gap: clamp(1rem, 2.4vw, 1.6rem); grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); }

  /* ===== 弓木サイトの注記＝画鋲メモ ===== */
  .ynote {
    position: relative; max-width: 620px; margin-top: 2rem;
    background: #FFFDF6; border-radius: 4px;
    box-shadow: 3px 5px 12px rgba(27,42,74,.16);
    padding: 1.05rem 1.25rem .95rem; transform: rotate(-1.2deg);
  }
  .ynote.in { transform: rotate(-1.2deg); }
  .ynote p { font-family: var(--f-hand); font-size: .98rem; line-height: 1.8; color: var(--ink); }
  .ynote b { color: var(--scarlet-d); font-weight: 400; }
  .ynote .pin {
    position: absolute; top: -9px; left: 28px;
    width: 17px; height: 17px; border-radius: 50%;
    background: radial-gradient(circle at 34% 30%, #ff8f70, var(--scarlet) 60%, var(--scarlet-d));
    box-shadow: 0 4px 6px rgba(0,0,0,.28);
  }

  /* ===== レスポンシブ ===== */
  @media (max-width: 720px) {
    .cf { display: none; }
    .trow { gap: .9rem; row-gap: .2rem; }
    .scribble { padding-bottom: .9rem; }
    .cat-head .ccnt { width: 46px; height: 46px; }
    .cat-head .ccnt b { font-size: 1.05rem; }
    .rule { margin-bottom: 1.5rem; }
  }
</style>
