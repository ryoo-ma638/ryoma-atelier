---
import { uriko, TEAM, SHORT } from '../data/uriko.ts';
const { year, month, games, homeVenue, handle } = uriko;

// 月曜はじまりのセル配列
const firstDow = (new Date(year, month - 1, 1).getDay() + 6) % 7; // Mon=0
const daysIn = new Date(year, month, 0).getDate();
const cells: (number | null)[] = [];
for (let i = 0; i < firstDow; i++) cells.push(null);
for (let d = 1; d <= daysIn; d++) cells.push(d);
while (cells.length % 7) cells.push(null);

const WD = ['MON', 'TUE', 'WED', 'THU', 'FRI', 'SAT', 'SUN'];
const isHome = (v: string) => v.startsWith(homeVenue);

// イベント（シリーズ）を集計
const events = new Map<string, number[]>();
for (const [d, g] of Object.entries(games)) {
  if (g.event) { const a = events.get(g.event) ?? []; a.push(+d); events.set(g.event, a); }
}
const workCount = Object.values(games).filter((g) => g.work).length;
---
<section class="cal-wrap" id="calendar">
  <div class="wrap">
    <p class="eyebrow reveal"><span class="dot"></span>売り子カレンダー · {handle}</p>
    <div class="cal-head reveal d1">
      <h2 class="big"><span class="y">{year}</span>年 <span class="m">{month}</span>月</h2>
      <p class="cal-sub hand">今月は <b>{workCount}試合</b> 出勤予定。バンテリンドームで待ってます🍺</p>
      <img class="cal-uma" src="/assets/mascot/cheers.png" alt="" aria-hidden="true" />
    </div>

    <div class="cal reveal d2">
      <span class="tape" aria-hidden="true"></span>
      <div class="grid">
        {WD.map((w, i) => (
          <div class={`wd ${i === 5 ? 'sat' : ''} ${i === 6 ? 'sun' : ''}`}>{w}</div>
        ))}
        {cells.map((d, i) => {
          if (d === null) return <div class="cell empty"></div>;
          const col = i % 7;
          const g = games[d];
          const home = g ? isHome(g.venue) : false;
          const t = g ? TEAM[g.opp] : null;
          const label = g ? (SHORT[g.opp] ?? g.opp) : '';
          const badgeStyle = g && t
            ? (home
                ? `background:${t.bg};color:${t.fg};border:2px solid ${t.bg}`
                : `background:#fff;color:${t.bg};border:2px solid ${t.bg}`)
            : '';
          return (
            <div class={`cell ${col === 5 ? 'sat' : ''} ${col === 6 ? 'sun' : ''} ${home ? 'home' : ''} ${g?.work ? 'work' : ''} ${g?.event ? 'event' : ''}`}>
              <span class="d">{d}{home && <b class="h">H</b>}</span>
              {g && (
                <div class="ginfo">
                  <span class="badge" style={badgeStyle}>{label}</span>
                  <span class={`v ${home ? 'vh' : ''}`}><span class="vn">{g.venue}</span><span class="vt">{g.time}</span></span>
                </div>
              )}
              {g?.onecoin && <span class="coin">500<small>円</small></span>}
              {g?.work && <img class="uma" src="/assets/mascot/logo3d.png" alt="出勤" />}
            </div>
          );
        })}
      </div>

      <div class="legend">
        <span class="lg"><img class="umini" src="/assets/mascot/logo3d.png" alt="" />＝出勤予定日</span>
        <span class="lg"><b class="h">H</b>＝ホーム（バンテリンドーム）</span>
        {[...events.keys()].map((name) => (
          <span class="lg"><span class="sw"></span>{name}</span>
        ))}
        <span class="lg note">※予定は変わることがあります</span>
      </div>
    </div>
  </div>

  <style>
    .cal-wrap { padding-block: clamp(2.5rem, 6vw, 4rem); }
    .cal-head { display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; margin: .4rem 0 1.4rem; }
    .cal-head .y, .cal-head .m { color: var(--amber-d); }
    .cal-sub { color: var(--scarlet-d); font-size: 1.06rem; rotate: -1deg; }
    .cal-sub b { color: var(--scarlet); font-size: 1.15em; }
    .cal-uma {
      width: clamp(64px, 7vw, 92px); margin-left: auto; align-self: flex-end;
      filter: drop-shadow(2px 4px 4px rgba(27,42,74,.2)); rotate: 5deg;
      transition: rotate .25s var(--spring), translate .25s var(--spring);
    }
    .cal-uma:hover { rotate: -4deg; translate: 0 -6px; }

    .cal { position: relative; background: var(--card); border: 2px solid var(--ink); border-radius: var(--r-lg); padding: clamp(.6rem, 2vw, 1.2rem); box-shadow: var(--sh-2); }
    .grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 5px; }
    .wd { text-align: center; font-family: var(--f-mono); font-size: .66rem; font-weight: 700; color: var(--mut); padding: .3rem 0; }
    .wd.sat { color: #2a7fd4; } .wd.sun { color: var(--scarlet); }

    .cell { position: relative; min-height: 92px; border-radius: 10px; background: var(--paper-2); border: 1.5px solid var(--paper-3); padding: 4px 5px; overflow: hidden; }
    .cell.empty { background: transparent; border: none; }
    .cell.home { background: color-mix(in oklab, #2a7fd4 12%, var(--paper-2)); border-color: color-mix(in oklab, #2a7fd4 30%, var(--paper-3)); }
    .cell.event { background: color-mix(in oklab, #2ba8e0 16%, var(--paper-2)); }
    .cell.work { border: 2px solid var(--amber); box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--amber) 40%, transparent); }

    .d { font-family: var(--f-round); font-weight: 700; font-size: .82rem; color: var(--ink); }
    .cell.sat .d { color: #2a7fd4; } .cell.sun .d { color: var(--scarlet); }
    .h { display: inline-block; background: #1660c8; color: #fff; font-size: .56rem; font-weight: 800; border-radius: 4px; padding: 0 4px; margin-left: 3px; vertical-align: 1px; }

    .ginfo { display: flex; flex-direction: column; align-items: center; margin-top: 2px; }
    .badge { min-width: 30px; height: 30px; padding: 0 6px; border-radius: 999px; display: inline-flex; align-items: center; justify-content: center; font-family: var(--f-round); font-weight: 800; font-size: .72rem; box-shadow: 0 1px 3px rgba(0,0,0,.2); }
    .v { text-align: center; font-weight: 700; color: var(--mut); line-height: 1.3; margin-top: 2px; }
    .v .vn { display: block; font-size: .6rem; }
    .v .vt { display: block; font-family: var(--f-mono); font-size: .62rem; }
    .v.vh { color: #0b4fb3; }
    .coin { position: absolute; right: 3px; bottom: 3px; background: radial-gradient(circle at 35% 30%, #fff3c4, #d4a017 72%); border: 2px solid #b8860b; color: #5c3a00; font-weight: 800; font-size: .58rem; border-radius: 999px; padding: 2px 5px; }
    .coin small { font-size: .8em; }
    .uma { position: absolute; top: 2px; right: 3px; width: 24px; height: 24px; object-fit: contain; filter: drop-shadow(0 1px 1px rgba(0,0,0,.2)); }

    .legend { display: flex; flex-wrap: wrap; gap: .5rem 1.1rem; margin-top: 1rem; padding-top: .9rem; border-top: 2px dashed color-mix(in oklab, var(--amber) 36%, var(--paper-3)); }
    .lg { display: inline-flex; align-items: center; gap: .35rem; font-family: var(--f-hand); font-size: .84rem; color: var(--ink); }
    .lg .umini { width: 22px; height: 22px; }
    .lg .sw { width: 16px; height: 16px; border-radius: 4px; background: color-mix(in oklab, #2ba8e0 40%, var(--paper)); }
    .lg.note { color: var(--mut); }

    @media (max-width: 640px) {
      .cell { min-height: 76px; }
      .badge { min-width: 26px; height: 26px; font-size: .64rem; }
      .uma { width: 20px; height: 20px; }
      .cal-uma { display: none; }
    }
    @media (max-width: 520px) {
      .v .vn { display: none; } /* 会場名は狭幅では隠す（Hバッジとセルの色で判別） */
      .v .vt { font-size: .66rem; }
    }
    @media (max-width: 430px) {
      .grid { gap: 3px; }
      .cell { min-height: 62px; padding: 2px 3px; }
      .d { font-size: .74rem; }
      .h { font-size: .6rem; }
    }
  </style>
</section>
