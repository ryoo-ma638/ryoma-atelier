---
import { works, categoryLabels } from '../data/works.ts';

// 下部「つくってるもの」ストリップ：7分野すべて（日本語＋件数＝分野の横断を一目で）
const stripOrder = ['web', 'imaging', 'cg', 'video', 'planning', 'graphic', 'sound'] as const;
const SHORT_EN: Record<string, string> = {
  web: 'APP', imaging: 'IMAGE', cg: 'CG', video: 'MOVIE', planning: 'PLAN', graphic: 'DESIGN', sound: 'SOUND',
};
const strip = stripOrder
  .map((c) => {
    const rep = works.find((w) => w.category === c && w.thumb);
    const n = works.filter((w) => w.category === c).length;
    return rep ? { cat: c, en: SHORT_EN[c], ja: categoryLabels[c].ja, n, color: categoryLabels[c].color, thumb: rep.thumb } : null;
  })
  .filter(Boolean) as { cat: string; en: string; ja: string; n: number; color: string; thumb: string }[];
---
<section class="hero" id="top">
  <div class="wrap grid">
    <!-- ===== 左：ことば ===== -->
    <div class="lead-col">
      <h1 class="title">
        <span class="l1">稜馬<span class="of">の</span><span class="hanko" data-stamp aria-hidden="true">馬</span></span>
        <span class="l2">ポートフォリオ
          <svg class="draw-line under" viewBox="0 0 340 18" preserveAspectRatio="none" aria-hidden="true" style="--len:360">
            <path d="M6,12 C70,4 130,16 190,9 C240,3 300,14 334,7" />
          </svg>
        </span>
      </h1>

      <p class="hand catch">つくるって、たのしい！
        <svg class="swoosh" viewBox="0 0 220 14" preserveAspectRatio="none" aria-hidden="true"><path d="M4,10 C60,4 150,12 216,5" /></svg>
      </p>

      <p class="chips-line">
        <span class="kw">ゲーム</span><span class="sl">/</span><span class="kw">CG</span><span class="sl">/</span><span class="kw">アプリ</span><span class="sl">/</span><span class="kw">画像処理</span><span class="dots"> …</span><br />
        <b>ワクワクするものを、まっすぐつくる！</b>
      </p>

      <p class="intro">
        愛知工業大学で<b>CGと画像処理</b>を学ぶ3年生。<br />
        <b>つくる人</b>で、バンテリンドームの<b>ビール売り子</b>です。<br />
        <span class="warm">まっすぐ、たのしく、あたたかい作品を届けます！</span>
      </p>

      <div class="cta">
        <a class="btn" href="/works">作品を見る<span class="ar">→</span></a>
        <a class="btn ghost" href="/about">ぼくのこと →</a>
      </div>
    </div>

    <!-- ===== 右：本人写真（クリーンな琥珀の円＋落書き） ===== -->
    <div class="art-col" aria-hidden="true" data-px-scene>
      <span class="ring" data-px="4"></span>
      <span class="ring2"></span>
      <svg class="lines" viewBox="0 0 300 120" preserveAspectRatio="none">
        <path d="M8,18 L210,10" /><path d="M30,52 L290,40" /><path d="M14,90 L180,84" />
      </svg>
      <span class="cf c1"></span><span class="cf c2"></span><span class="cf c3"></span><span class="cf c4"></span>

      <div class="photo" data-px="7">
        <img src="/assets/about/portrait.jpg" alt="大崎稜馬のポートレート" />
      </div>

      <span class="doodle d-cg hand" data-px="18">✦ CG →</span>
      <span class="doodle d-ip hand" data-px="12">IMAGE<br />PROCESSING</span>
    </div>
  </div>

  <!-- ===== うまくんの走路（画面の端から端へ駆け抜ける） ===== -->
  <div class="runway" aria-hidden="true">
    <span class="track"></span>
    <span class="dash" data-horse>
      <span class="gallop">
        <img class="f1" src="/assets/mascot/run.png" alt="" />
        <img class="f2" src="/assets/mascot/run2.png" alt="" />
      </span>
    </span>
  </div>

  <!-- ===== 下部：つくってるもの（7分野・横スクロール） ===== -->
  <div class="wrap belt">
    <div class="belt-head">
      <span class="belt-label hand">つくってるもの <span class="bulb">💡</span></span>
      <span class="belt-hint hand">よこにスクロールできるよ <b class="hint-ar">→</b></span>
    </div>
    <div class="strip-wrap">
      <div class="strip">
        {strip.map((s) => (
          <a class="fcard" href={`/works#cat-${s.cat}`} style={`--tag:${s.color}`}>
            <span class="flabel">{s.en}</span>
            <span class="fthumb"><img src={s.thumb} alt="" loading="lazy" /></span>
            <span class="fja">{s.ja}<b>{s.n}</b></span>
            <span class="fgo">→</span>
          </a>
        ))}
        <a class="fcard all" href="/works">
          <span class="all-in"><b>27</b>作品<br />ぜんぶ見る →</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero { position: relative; padding-top: clamp(1.2rem, 3vw, 2.4rem); overflow: clip; }
  .grid { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: clamp(.8rem, 2.5vw, 2rem); align-items: center; }

  /* ---- 左：ことば ---- */
  .title { font-size: clamp(2.6rem, 6vw, 5.2rem); line-height: 1.04; letter-spacing: .01em; }
  .title .l1, .title .l2 { display: block; white-space: nowrap; }
  .title .l1 { position: relative; width: fit-content; }
  .title .of { color: var(--mut); font-weight: 700; font-size: .52em; margin-left: .06em; }
  .title .l2 { position: relative; width: fit-content; color: var(--ink); transform: rotate(-.6deg); }
  .draw-line.under { position: absolute; left: -1%; bottom: -.12em; width: 102%; height: .22em; overflow: visible; }
  .draw-line.under path { fill: none; stroke: var(--amber); stroke-width: 8; stroke-linecap: round; }

  .hanko {
    position: absolute; top: -.12em; right: -1.5em;
    width: 1em; height: 1em; display: grid; place-items: center;
    font-family: var(--f-round); font-weight: 700; font-size: .42em; color: #fff;
    background: var(--scarlet); border-radius: 50%;
    box-shadow: inset 0 0 0 2.5px rgba(255,255,255,.4), 1px 2px 4px rgba(27,42,74,.18);
    opacity: 0; transform: scale(1.8) rotate(-18deg);
  }
  .hanko.stamped { animation: stamp .5s var(--spring) forwards; }
  @keyframes stamp {
    0% { opacity: 0; transform: scale(1.8) rotate(-18deg); }
    55% { opacity: 1; transform: scale(.9) rotate(6deg); }
    100% { opacity: 1; transform: scale(1) rotate(-8deg); }
  }

  .catch { position: relative; width: fit-content; color: var(--scarlet); font-size: clamp(1.2rem, 2.4vw, 1.6rem); margin-top: 1.2rem; transform: rotate(-1.6deg); }
  .swoosh { position: absolute; left: 2%; bottom: -.45em; width: 96%; height: .5em; overflow: visible; }
  .swoosh path { fill: none; stroke: var(--scarlet); stroke-width: 2.5; stroke-linecap: round; opacity: .85; }

  .chips-line { margin-top: 1.1rem; font-weight: 700; line-height: 2; }
  .chips-line .kw { display: inline-block; background: var(--ink); color: var(--paper); padding: .12rem .55rem; border-radius: 8px; margin-right: .1rem; font-size: .9rem; }
  .chips-line .sl { color: var(--amber-d); font-weight: 900; margin: 0 .22rem; }
  .chips-line .dots { color: var(--mut); }
  .chips-line b { color: var(--ink); font-size: clamp(1rem, 2vw, 1.18rem); }

  .intro { margin-top: 1rem; font-weight: 700; font-size: clamp(.95rem, 1.6vw, 1.1rem); line-height: 2; }
  .intro b { color: var(--ink); border-bottom: 3px solid var(--amber); white-space: nowrap; }
  .intro .warm { color: var(--scarlet-d); }

  .cta { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1.5rem; }
  .cta .ar { transition: transform .2s var(--spring); margin-left: .15rem; }
  .btn:hover .ar { transform: translateX(4px); }

  /* ---- 右：クリーンな円＋写真（MacBook幅でも見切れない） ---- */
  .art-col { position: relative; min-height: clamp(380px, 34vw, 540px); }

  /* 背景＝琥珀のきれいな円（名刺のたてがみ色。ロゴ的なワンサークル） */
  .ring {
    position: absolute; inset: 8% 0% 4% 14%;
    background: var(--amber); border-radius: 50%;
    transform: rotate(-6deg);
    box-shadow: inset -10px -14px 0 rgba(201,135,31,.35);
  }
  /* 紺の細いリング＝理系のキレをひとつだけ */
  .ring2 {
    position: absolute; top: 2%; left: 4%; width: 22%; aspect-ratio: 1;
    border: 3.5px solid var(--ink); border-radius: 50%; opacity: .18;
  }

  .lines { position: absolute; top: 1%; right: 6%; width: 165px; height: 66px; z-index: 3; }
  .lines path { fill: none; stroke: var(--ink); stroke-width: 4; stroke-linecap: round; opacity: .5; }

  .cf { position: absolute; width: 12px; height: 12px; z-index: 4; border-radius: 2px; }
  .cf.c1 { top: 6%; left: 6%; background: var(--scarlet); transform: rotate(20deg); }
  .cf.c2 { top: 46%; left: 8%; background: var(--amber-d); transform: rotate(-14deg); width: 9px; height: 9px; }
  .cf.c3 { bottom: 4%; left: 30%; background: var(--ink); transform: rotate(40deg); width: 9px; height: 9px; }
  .cf.c4 { bottom: 14%; right: 1%; background: var(--scarlet); transform: rotate(-28deg); width: 10px; height: 10px; }

  /* 写真＝画面内に完全に収まるブロブ */
  .photo {
    position: absolute; inset: 2% 3% 8% 22%; z-index: 2;
    border-radius: 48% 52% 44% 56% / 54% 46% 54% 46%;
    overflow: hidden; background: var(--paper-3);
    border: 4px solid var(--ink);
    box-shadow: 0 16px 36px rgba(27,42,74,.22);
  }
  .photo img { width: 100%; height: 100%; object-fit: cover; object-position: 50% 18%; }

  .doodle { position: absolute; z-index: 5; color: var(--ink); font-size: 1rem; }
  .doodle.d-cg { top: 34%; left: 8%; transform: rotate(-8deg); font-size: 1.1rem; }
  .doodle.d-ip { bottom: 0; right: 4%; color: var(--ink); font-size: .92rem; line-height: 1.3; text-align: right; transform: rotate(2deg); }

  /* ---- うまくんの走路（全幅を駆け抜ける） ---- */
  .runway { position: relative; height: clamp(78px, 8vw, 108px); margin-top: .6rem; }
  .track { position: absolute; left: 0; right: 0; bottom: 18px; height: 3px; background: color-mix(in oklab, var(--amber) 55%, var(--paper)); }
  .track::after { content: ''; position: absolute; right: 0; bottom: -4.5px; border-left: 12px solid color-mix(in oklab, var(--amber) 80%, var(--paper)); border-top: 6px solid transparent; border-bottom: 6px solid transparent; }

  .dash {
    position: absolute; bottom: 18px; left: 0;
    width: clamp(120px, 11.5vw, 165px);
    transform: translateX(-130%);
    animation: dash 12s linear infinite;
    will-change: transform;
  }
  /* 端から端へ駆け抜けて、しばらくお休み、また走る */
  @keyframes dash {
    0%       { transform: translateX(-130%); }
    52%      { transform: translateX(calc(100vw + 30%)); }
    100%     { transform: translateX(calc(100vw + 30%)); }
  }
  .gallop { display: block; position: relative; transform-origin: 55% 88%; animation: hoof .46s ease-in-out infinite; }
  .gallop img { width: 100%; height: auto; display: block; filter: drop-shadow(3px 5px 5px rgba(27,42,74,.2)); }
  .gallop .f2 { position: absolute; inset: 0; }
  .gallop .f1 { animation: flipA .46s steps(1) infinite; }
  .gallop .f2 { animation: flipB .46s steps(1) infinite; }
  @keyframes flipA { 0%, 49.9% { opacity: 1; } 50%, 100% { opacity: 0; } }
  @keyframes flipB { 0%, 49.9% { opacity: 0; } 50%, 100% { opacity: 1; } }
  @keyframes hoof { 0%,100% { transform: translateY(0) rotate(calc(var(--lean, 0deg) - 1deg)); } 50% { transform: translateY(-6px) rotate(calc(var(--lean, 0deg) + 1deg)); } }
  /* 砂ぼこり */
  .gallop::before, .gallop::after {
    content: ''; position: absolute; border-radius: 50%;
    background: radial-gradient(circle, rgba(255,252,244,.9), rgba(232,161,58,.32) 60%, transparent 72%);
  }
  .gallop::before { left: -7%; bottom: 5%; width: 14%; height: 9%; animation: dust .46s ease-out infinite; }
  .gallop::after  { left: -13%; bottom: 12%; width: 9%; height: 6%; animation: dust .46s ease-out .18s infinite; }
  @keyframes dust { 0% { opacity: .6; transform: scale(.5); } 100% { opacity: 0; transform: scale(1.5) translateX(-12px); } }

  /* 動きを控えたい人には：右端で静止 */
  @media (prefers-reduced-motion: reduce) {
    .dash { animation: none; left: auto; right: 4%; transform: none; }
  }

  /* ---- 下部ストリップ（左寄せ・全幅・スクロールの合図つき） ---- */
  .belt { margin-top: .4rem; }
  .belt-head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: .4rem; }
  .belt-label { color: var(--scarlet-d); font-size: 1.1rem; transform: rotate(-1.6deg); }
  .belt-hint { color: var(--mut); font-size: .88rem; }
  .belt-hint .hint-ar { display: inline-block; color: var(--amber-d); animation: hintgo 1.6s ease-in-out infinite; }
  @keyframes hintgo { 0%, 100% { transform: translateX(0); } 50% { transform: translateX(6px); } }

  /* 右端フェード＝「まだ続きがある」の合図 */
  .strip-wrap { position: relative; }
  .strip-wrap::after {
    content: ''; position: absolute; top: 0; bottom: .5rem; right: 0; width: 64px; pointer-events: none;
    background: linear-gradient(to right, transparent, var(--paper));
  }
  .strip { display: flex; gap: .8rem; overflow-x: auto; padding: .3rem 3.2rem .5rem 0; scrollbar-width: thin; }
  .fcard {
    position: relative; flex: 0 0 auto; width: 168px;
    background: var(--ink); border-radius: 14px; overflow: hidden;
    box-shadow: 0 6px 14px rgba(27,42,74,.24);
    transition: transform .2s var(--spring), box-shadow .2s ease;
  }
  .fcard:hover { transform: translateY(-7px) rotate(-1.2deg); box-shadow: 0 12px 22px rgba(27,42,74,.3); }
  .flabel { display: block; font-family: var(--f-mono); font-size: .72rem; font-weight: 700; letter-spacing: .08em; color: #fff; padding: .5rem .7rem .35rem; }
  .fthumb { display: block; aspect-ratio: 16/9; }
  .fthumb img { width: 100%; height: 100%; object-fit: cover; opacity: .92; transition: transform .35s var(--ease); }
  .fja { display: flex; align-items: center; justify-content: space-between; gap: .4rem; color: var(--paper); font-size: .68rem; font-weight: 700; padding: .35rem .7rem .45rem; }
  .fja b { font-family: var(--f-mono); font-size: .72rem; color: var(--amber-l); }
  .fcard:hover .fthumb img { transform: scale(1.07); }
  .fgo { position: absolute; right: .55rem; top: .38rem; color: var(--amber); font-weight: 900; font-size: .95rem; transition: transform .2s var(--spring); }
  .fcard:hover .fgo { transform: translateX(3px); }
  .fcard::after { content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 3px; background: var(--tag); }

  /* 最後の「ぜんぶ見る」カード */
  .fcard.all { display: grid; place-items: center; background: var(--amber); box-shadow: 0 6px 14px rgba(201,135,31,.4); }
  .fcard.all .all-in { font-family: var(--f-round); font-weight: 700; color: #3a2606; text-align: center; line-height: 1.5; font-size: .92rem; }
  .fcard.all .all-in b { font-family: var(--f-mono); font-size: 1.5rem; margin-right: .1rem; }
  .fcard.all::after { background: var(--ink); }

  /* ---- レスポンシブ ---- */
  @media (max-width: 980px) {
    .grid { grid-template-columns: 1fr; }
    .art-col { order: 2; min-height: 380px; }
    .photo { inset: 2% 6% 8% 18%; }
  }
  @media (max-width: 560px) {
    .title { font-size: clamp(2.35rem, 11.5vw, 3rem); }
    .art-col { min-height: 320px; }
    .doodle.d-cg { display: none; }
    .lines { width: 140px; }
    .dash { width: 130px; }
  }
</style>
