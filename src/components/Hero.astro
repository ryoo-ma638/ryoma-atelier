---
import { works, categoryLabels } from '../data/works.ts';

// 下部「つくってるもの」ストリップ用：分野ごとの代表サムネを1枚ずつ。
const stripOrder = ['cg', 'imaging', 'web', 'video', 'planning', 'graphic'] as const;
const strip = stripOrder
  .map((c) => {
    const rep = works.find((w) => w.category === c && w.thumb);
    return rep ? { cat: c, label: categoryLabels[c], thumb: rep.thumb } : null;
  })
  .filter(Boolean) as { cat: string; label: { ja: string; en: string; color: string }; thumb: string }[];
---
<section class="hero" id="top">
  <div class="wrap grid">
    <!-- ===== 左：ことば ===== -->
    <div class="lead-col">
      <h1 class="title">
        <span class="nm">稜馬<span class="hanko" data-stamp aria-hidden="true">馬</span></span><span class="of">の</span><br />
        <span class="pf">ポートフォリオ
          <svg class="draw-line under" viewBox="0 0 340 20" preserveAspectRatio="none" aria-hidden="true" style="--len:360">
            <path d="M6,13 C70,4 130,18 190,10 C240,3 300,15 334,8" />
          </svg>
        </span>
      </h1>

      <p class="hand">つくるって、たのしい！</p>

      <p class="chips-line">
        <span class="kw">ゲーム</span><span class="sl">/</span><span class="kw">CG</span><span class="sl">/</span><span class="kw">アプリ</span><span class="sl">/</span><span class="kw">画像処理</span><span class="dots">…</span><br />
        <b>ワクワクするものを、まっすぐつくる！</b>
      </p>

      <p class="intro">
        愛知工業大学で <b>CGと画像処理</b> を学ぶ3年生。<br />
        <b>つくる人</b>で、バンテリンドームの <b>ビール売り子</b> です。<br />
        <span class="warm">まっすぐ、たのしく、あたたかい作品を届けます！</span>
      </p>

      <p class="two-tags">
        <span class="chip c1">つくる人</span>
        <span class="chip c2">ビール売り子</span>
      </p>

      <div class="cta">
        <a class="btn" href="/works">作品を見る<span class="ar">→</span></a>
        <a class="btn ghost" href="/about">ぼくのこと →</a>
      </div>
    </div>

    <!-- ===== 右：ビジュアル（本人写真ゾーン＋マスコット） ===== -->
    <div class="art-col" aria-hidden="true">
      <span class="brush b1"></span>
      <span class="brush b2"></span>

      <!-- 本人写真（イメージ・後日実写へ差し替え可） -->
      <div class="photo">
        <img src="/assets/photo/hero.jpg" alt="バンテリンドームのビール売り子（イメージ）" />
      </div>

      <!-- 落書きラベル -->
      <span class="doodle d-game">🎮 GAME</span>
      <span class="doodle d-cg">✦ CG</span>
      <span class="doodle d-ip">IMAGE<br />PROCESSING</span>

      <!-- 案内役のうまくん（2枚のフレームを交互に＝疾走） -->
      <span class="pony" data-horse>
        <img class="f1" src="/assets/mascot/run.png" alt="案内役のうまくん" />
        <img class="f2" src="/assets/mascot/run2.png" alt="" aria-hidden="true" />
      </span>
      <span class="hello">うまくん、よろしく！</span>
    </div>
  </div>

  <!-- ===== 下部：つくってるもの ストリップ ＋ 画鋲メモ ===== -->
  <div class="wrap belt">
    <span class="belt-label">つくってるもの <span class="bulb">💡</span></span>
    <div class="strip">
      {strip.map((s) => (
        <a class="fcard" href={`/works#cat-${s.cat}`} style={`--tag:${s.label.color}`}>
          <span class="fthumb"><img src={s.thumb} alt="" loading="lazy" /></span>
          <span class="flabel">{s.label.en}<span class="ar">→</span></span>
        </a>
      ))}
    </div>

    <aside class="pin-note">
      <span class="pin" aria-hidden="true"></span>
      <span class="hanko-mini" aria-hidden="true">馬</span>
      <p>まっすぐに、<br />つくって、<br />手渡す！</p>
    </aside>
  </div>
</section>

<style>
  .hero { position: relative; padding-top: clamp(1.5rem, 4vw, 3rem); overflow: hidden; }
  .grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: clamp(1rem, 3vw, 2.5rem); align-items: center; }

  /* ---- 左：ことば ---- */
  .title { font-size: clamp(2.8rem, 8.5vw, 6.4rem); line-height: .95; }
  .title .nm { position: relative; color: var(--ink); }
  .title .of { color: var(--mut); font-weight: 700; font-size: .5em; }
  .title .pf { position: relative; display: inline-block; color: var(--ink); }
  .draw-line.under { position: absolute; left: 0; right: 0; bottom: -.05em; width: 100%; height: .22em; overflow: visible; }
  .draw-line.under path { fill: none; stroke: var(--amber); stroke-width: 9; stroke-linecap: round; }
  .hanko {
    position: absolute; top: -.1em; right: -.7em; width: 1em; height: 1em; display: grid; place-items: center;
    font-family: var(--f-round); font-weight: 700; font-size: .34em; color: #fff;
    background: var(--scarlet); border-radius: 24% 26% 22% 28%; box-shadow: inset 0 0 0 3px rgba(255,255,255,.35);
    opacity: 0; transform: scale(1.8) rotate(-18deg);
  }
  .hanko.stamped { animation: stamp .5s var(--spring) forwards; }
  @keyframes stamp { 0% { opacity: 0; transform: scale(1.8) rotate(-18deg); } 55% { opacity: 1; transform: scale(.9) rotate(6deg); } 100% { opacity: 1; transform: scale(1) rotate(-7deg); } }

  .hand { font-family: var(--f-round); font-weight: 700; color: var(--amber-d); font-size: clamp(1.1rem, 3vw, 1.6rem); margin-top: 1.1rem; transform: rotate(-2deg); display: inline-block; }

  .chips-line { margin-top: .9rem; font-weight: 700; }
  .chips-line .kw { display: inline-block; background: var(--ink); color: var(--paper); padding: .1rem .5rem; border-radius: 7px; margin: 0 .1rem .35rem; font-size: .95rem; }
  .chips-line .sl { color: var(--amber-d); font-weight: 900; margin: 0 .15rem; }
  .chips-line .dots { color: var(--mut); }
  .chips-line b { color: var(--ink); font-size: clamp(1rem, 2.4vw, 1.25rem); }

  .intro { margin-top: 1.1rem; font-weight: 700; font-size: clamp(.95rem, 1.8vw, 1.1rem); max-width: 34ch; }
  .intro b { color: var(--ink); border-bottom: 3px solid var(--amber); }
  .intro .warm { color: var(--scarlet-d); }

  .two-tags { display: flex; gap: .5rem; margin-top: 1.1rem; }
  .chip { font-family: var(--f-round); font-size: .8rem; padding: .3rem .8rem; border-radius: var(--r-pill); font-weight: 700; }
  .chip.c1 { background: color-mix(in oklab, var(--ink) 12%, var(--paper)); color: var(--ink); }
  .chip.c1::before { content: '● '; color: var(--amber-d); }
  .chip.c2 { background: color-mix(in oklab, var(--scarlet) 16%, var(--paper)); color: var(--scarlet-d); }
  .chip.c2::before { content: '● '; color: var(--scarlet); }

  .cta { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1.6rem; }
  .cta .ar { transition: transform .2s var(--spring); }
  .btn:hover .ar { transform: translateX(4px); }

  /* ---- 右：ビジュアル ---- */
  .art-col { position: relative; min-height: 460px; }
  .brush { position: absolute; border-radius: 46% 54% 40% 60% / 55% 45% 55% 45%; filter: blur(2px); z-index: 0; }
  .brush.b1 { inset: 6% 2% 18% 10%; background: color-mix(in oklab, var(--amber) 60%, transparent); transform: rotate(-6deg); }
  .brush.b2 { inset: 20% 14% 8% 2%; background: color-mix(in oklab, var(--ink) 26%, transparent); transform: rotate(5deg); }

  .photo {
    position: absolute; inset: 6% 4% 14% 18%; z-index: 1;
    border-radius: 50% 46% 52% 48% / 52% 50% 50% 48%;
    border: 4px solid var(--ink); overflow: hidden; background: var(--paper-3);
    box-shadow: var(--sh-3);
  }
  .photo img { width: 100%; height: 100%; object-fit: cover; }

  .doodle { position: absolute; z-index: 2; font-family: var(--f-round); font-weight: 700; color: var(--ink); font-size: .85rem; }
  .doodle.d-game { top: 6%; right: 4%; color: var(--amber-d); transform: rotate(4deg); }
  .doodle.d-cg { top: 30%; left: -2%; color: var(--ink); transform: rotate(-6deg); }
  .doodle.d-ip { bottom: 12%; right: 2%; color: var(--scarlet-d); font-size: .78rem; line-height: 1.1; text-align: right; }

  .pony {
    position: absolute; bottom: 1%; left: 2%; width: 240px; z-index: 3;
    transform-origin: 60% 90%;
    animation: hoof .28s ease-in-out infinite;
    filter: drop-shadow(3px 5px 4px rgba(27,42,74,.18));
  }
  .pony img { width: 100%; height: auto; display: block; }
  .pony .f2 { position: absolute; inset: 0; opacity: 0; }
  /* 2枚を交互に切り替え＝ギャロップ */
  .pony .f1 { animation: flipA .28s steps(1) infinite; }
  .pony .f2 { animation: flipB .28s steps(1) infinite; }
  @keyframes flipA { 0%, 49.9% { opacity: 1; } 50%, 100% { opacity: 0; } }
  @keyframes flipB { 0%, 49.9% { opacity: 0; } 50%, 100% { opacity: 1; } }
  .pony::after { content: ''; position: absolute; left: -12px; bottom: 6px; width: 26px; height: 12px; border-radius: 50%; background: radial-gradient(circle, color-mix(in oklab, var(--amber) 45%, var(--paper)), transparent 70%); animation: dust .28s ease-out infinite; z-index: 2; }
  @keyframes hoof { 0%,100% { transform: translateY(0) rotate(var(--lean, 0deg)); } 50% { transform: translateY(-5px) rotate(var(--lean, 0deg)); } }
  @keyframes dust { 0% { opacity: .6; transform: scale(.6); } 100% { opacity: 0; transform: scale(1.6) translateX(-10px); } }
  .hello {
    position: absolute; bottom: 40%; left: 4%; z-index: 4;
    background: var(--card); border: 2px solid var(--ink); border-radius: 14px 14px 14px 3px;
    padding: .35rem .8rem; font-family: var(--f-round); font-weight: 700; font-size: .95rem; box-shadow: var(--sh-2);
    animation: floaty 3s ease-in-out infinite;
  }
  @keyframes floaty { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }

  /* ---- 下部ストリップ ---- */
  .belt { margin-top: 2.2rem; display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 1rem; }
  .belt-label { font-family: var(--f-round); font-weight: 700; color: var(--scarlet-d); white-space: nowrap; }
  .belt-label .bulb { filter: saturate(1.2); }
  .strip { display: flex; gap: .7rem; overflow-x: auto; padding-bottom: .3rem; scrollbar-width: thin; }
  .fcard {
    flex: 0 0 auto; width: 150px; background: var(--card); border: 2px solid var(--ink); border-radius: var(--r-md);
    overflow: hidden; box-shadow: var(--sh-1); transition: transform .2s var(--spring), box-shadow .2s ease;
  }
  .fcard:hover { transform: translateY(-6px) rotate(-1deg); box-shadow: var(--sh-2); }
  .fthumb { display: block; aspect-ratio: 16/10; background: var(--paper-3); }
  .fthumb img { width: 100%; height: 100%; object-fit: cover; }
  .flabel { display: flex; align-items: center; justify-content: space-between; font-family: var(--f-mono); font-size: .62rem; font-weight: 700; padding: .4rem .5rem; border-top: 3px solid var(--tag); }

  .pin-note {
    position: relative; flex: 0 0 auto; width: 150px; align-self: stretch;
    background: var(--card); border: 1px solid var(--paper-3); border-radius: 4px; box-shadow: var(--sh-2);
    padding: 1rem .8rem; transform: rotate(3deg); display: grid; place-items: center;
  }
  .pin-note p { font-family: var(--f-round); font-weight: 700; color: var(--ink); line-height: 1.5; }
  .pin { position: absolute; top: -8px; left: 50%; transform: translateX(-50%); width: 16px; height: 16px; border-radius: 50%; background: var(--scarlet); box-shadow: 0 3px 5px rgba(0,0,0,.25), inset -2px -2px 3px var(--scarlet-d); }
  .hanko-mini { position: absolute; right: 6px; bottom: 6px; width: 26px; height: 26px; display: grid; place-items: center; font-family: var(--f-round); font-weight: 700; font-size: .7rem; color: #fff; background: var(--scarlet); border-radius: 24% 26% 22% 28%; opacity: .9; }

  /* ---- レスポンシブ ---- */
  @media (max-width: 900px) {
    .grid { grid-template-columns: 1fr; }
    .art-col { min-height: 380px; order: 2; }
    .belt { grid-template-columns: 1fr; }
    .pin-note { justify-self: end; width: 160px; }
  }
  @media (max-width: 520px) {
    .art-col { min-height: 320px; }
    .pony { width: 165px; }
    .hello { display: none; }
  }
</style>
